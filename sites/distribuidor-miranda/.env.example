# =============================================================================
# DISTRIBUIDOR MIRANDA - PLANTILLA DE CONFIGURACIÓN
# =============================================================================
# Copiar este archivo a .env y rellenar con los valores reales
# =============================================================================

# ---------------------------------------------------------------------------
# SHOPIFY - Admin API (REST + GraphQL 2025-01)
# ---------------------------------------------------------------------------
SHOPIFY_STORE=distribuidor-miranda.myshopify.com
SHOPIFY_STORE_DOMAIN=distribuidor-miranda.myshopify.com
SHOPIFY_API_VERSION=2025-01
SHOPIFY_CLIENT_ID=xxx
SHOPIFY_CLIENT_SECRET=shpss_xxx
SHOPIFY_ACCESS_TOKEN=shpca_xxx
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxx

# ---------------------------------------------------------------------------
# SHOPIFY - Storefront API (Cliente web)
# ---------------------------------------------------------------------------
SHOPIFY_STOREFRONT_ACCESS_TOKEN=xxx
SHOPIFY_STOREFRONT_CLIENT_ID=xxx
SHOPIFY_STOREFRONT_CLIENT_SECRET=shpss_xxx
SHOPIFY_STOREFRONT_ADMIN_ACCESS_TOKEN=shpca_xxx
SHOPIFY_STOREFRONT_OAUTH_PORT=3000
SHOPIFY_CURRENCY_CODE=USD
SHOPIFY_LOCALE=es-EC

# ---------------------------------------------------------------------------
# CLOUDFLARE - Workers, KV, Pages
# ---------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=cfut_xxx
CLOUDFLARE_ACCOUNT_ID=948994a95e4d7d23badec650fa303120
CLOUDFLARE_KV_NAMESPACE_ID=45f129649a6c49668cf9b9ad5d645138

# ---------------------------------------------------------------------------
# WORKER - Configuración del sitio
# ---------------------------------------------------------------------------
WORKER_NAME=distribuidor-miranda-storefront
WORKER_URL=https://distribuidor-miranda-storefront.camilocuadros.workers.dev
WORKER_DOMAIN_PROD=distribuidormiranda.com.ec
WORKER_DOMAIN_WWW=www.distribuidormiranda.com.ec

# ---------------------------------------------------------------------------
# KINTO CMS
# ---------------------------------------------------------------------------
KINTO_SITE_ID=distribuidor-miranda
KINTO_API_KEY=xxx

# ---------------------------------------------------------------------------
# FEATURE FLAGS
# ---------------------------------------------------------------------------
SHOPIFY_CHECKOUT_SAME_DOMAIN=true
SHOPIFY_CHECKOUT_SUBDOMAIN=checkout
SHOPIFY_REBUILD_DEBOUNCE_SECONDS=90
SHOPIFY_FEATURED_COLLECTIONS=
