---
// Breadcrumbs.astro - Navegación de migas de pan
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav class="dm-breadcrumbs" aria-label="Breadcrumb">
  <ol class="dm-breadcrumbs-list">
    <li>
      <a href="/" class="dm-breadcrumb-link">Inicio</a>
    </li>
    {items.map((item, index) => (
      <li>
        <span class="dm-breadcrumb-separator">/</span>
        {item.href ? (
          <a href={item.href} class="dm-breadcrumb-link">{item.label}</a>
        ) : (
          <span class="dm-breadcrumb-current" aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .dm-breadcrumbs {
    padding: 16px 28px;
    max-width: 1440px;
    margin: 0 auto;
  }

  .dm-breadcrumbs-list {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 13px;
    color: var(--ink-3, #666);
  }

  .dm-breadcrumb-link {
    color: var(--ink-2, #333);
    transition: color 0.15s;
  }

  .dm-breadcrumb-link:hover {
    color: var(--accent, #f59e0b);
  }

  .dm-breadcrumb-separator {
    color: var(--ink-4, #999);
  }

  .dm-breadcrumb-current {
    color: var(--ink, #000);
    font-weight: 600;
  }

  @media (max-width: 720px) {
    .dm-breadcrumbs {
      padding: 12px 16px;
      font-size: 12px;
    }
  }
</style>
