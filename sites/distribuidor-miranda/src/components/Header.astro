---
import { getStorefrontCollections, isShopifyCollection, collectionHref } from '../lib/shopify-catalog';
const collections = await getStorefrontCollections();
const current = Astro.props.current || '';
---
<header class="dm-topbar">
  <div class="dm-utility"><div class="dm-utility-inner"><span>Envío a todo Ecuador en 24–48h</span><span>·</span><span>Quito · Guayaquil · Cuenca</span><span class="spacer"></span><span>Mayoristas: <strong>+593 99 614 0000</strong></span></div></div>
  <div class="dm-mainbar">
    <a href="/" class="dm-logo"><div class="dm-logo-mark"><span>DM</span></div><div><div class="dm-logo-name">Distribuidor Miranda</div><div class="dm-logo-sub">Repuestos de colisión · desde 1996</div></div></a>
    <form class="dm-search" action="/catalogo/todos/"><span>⌕</span><input name="q" placeholder="Buscar por código, parte, marca o modelo…" /><kbd>⌘K</kbd></form>
    <div class="dm-actions"><a class="dm-iconbtn" href="/catalogo/todos/">⇄</a><a class="dm-iconbtn" href="/catalogo/todos/">♡</a><a class="dm-cart" data-cart-trigger href="#">Carrito <span class="dm-cart-pill" data-cart-count hidden>0</span></a></div>
  </div>
  <nav class="dm-nav"><div class="dm-nav-inner"><a class="dm-nav-cats" href="/catalogo/todos/">☰ Todas las categorías</a>{collections.slice(0, 8).map(c => <a class={current === (isShopifyCollection(c) ? c.handle : c.id) ? 'active' : ''} href={collectionHref(c)}>{isShopifyCollection(c) ? c.title : c.label}</a>)}<span class="spacer"></span><a class="dm-nav-promo" href="/catalogo/todos/"><span class="dm-pulse"></span>Ofertas</a><a href="#mayoristas">Mayoristas</a><a href="#">Catálogo PDF</a></div></nav>
</header>
