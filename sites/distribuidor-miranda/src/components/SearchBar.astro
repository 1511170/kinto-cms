---
// SearchBar.astro - Buscador con autocomplete
---
<div class="dm-search-wrapper">
  <form class="dm-search" action="/buscar" method="GET">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    <input 
      type="search" 
      name="q" 
      placeholder="Buscar repuesto, código OEM, marca..." 
      autocomplete="off"
      id="search-input"
    />
    <kbd>⌘K</kbd>
  </form>
  <div class="dm-search-dropdown" id="search-dropdown" hidden>
    <div class="dm-search-section">
      <div class="dm-search-section-title">Búsquedas recientes</div>
      <div class="dm-search-items" id="search-recent"></div>
    </div>
    <div class="dm-search-section">
      <div class="dm-search-section-title">Sugerencias</div>
      <div class="dm-search-items" id="search-suggestions"></div>
    </div>
  </div>
</div>

<script>
  const input = document.getElementById('search-input');
  const dropdown = document.getElementById('search-dropdown');
  const recent = document.getElementById('search-recent');
  const suggestions = document.getElementById('search-suggestions');
  
  // Keyboard shortcut
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      input.focus();
    }
  });
  
  // Show dropdown on focus
  input.addEventListener('focus', () => {
    dropdown.hidden = false;
    loadRecent();
  });
  
  // Hide dropdown on click outside
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.dm-search-wrapper')) {
      dropdown.hidden = true;
    }
  });
  
  // Load recent searches
  function loadRecent() {
    const items = JSON.parse(localStorage.getItem('searchRecent') || '[]');
    recent.innerHTML = items.slice(0, 5).map(q => 
      `<a href="/buscar?q=${encodeURIComponent(q)}" class="dm-search-item">${q}</a>`
    ).join('') || '<span class="dm-search-empty">No hay búsquedas recientes</span>';
  }
  
  // Save search on submit
  input.closest('form').addEventListener('submit', () => {
    const q = input.value.trim();
    if (q) {
      const items = JSON.parse(localStorage.getItem('searchRecent') || '[]');
      items.unshift(q);
      localStorage.setItem('searchRecent', JSON.stringify(items.slice(0, 10)));
    }
  });
  
  // Autocomplete
  let debounce;
  input.addEventListener('input', () => {
    clearTimeout(debounce);
    debounce = setTimeout(() => {
      const q = input.value.trim();
      if (q.length < 2) return;
      
      // Fetch suggestions from search index
      fetch(`/search-index.json?q=${encodeURIComponent(q)}`)
        .then(r => r.json())
        .then(data => {
          suggestions.innerHTML = data.slice(0, 5).map(p => 
            `<a href="${p.url}" class="dm-search-item">
              <span class="dm-search-item-title">${p.title}</span>
              <span class="dm-search-item-sku">${p.sku || ''}</span>
            </a>`
          ).join('');
        });
    }, 150);
  });
</script>

<style>
  .dm-search-wrapper {
    position: relative;
    flex: 1;
    max-width: 600px;
  }
  
  .dm-search {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0 18px;
    height: 48px;
    transition: border-color 0.2s;
  }
  
  .dm-search:focus-within {
    border-color: var(--accent);
  }
  
  .dm-search input {
    flex: 1;
    border: 0;
    background: transparent;
    outline: 0;
    color: var(--ink);
    font-size: 15px;
  }
  
  .dm-search kbd {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 3px 8px;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: var(--surface);
    color: var(--ink-3);
  }
  
  .dm-search-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 12px;
    box-shadow: var(--shadow-lg);
    padding: 12px;
    z-index: 100;
  }
  
  .dm-search-section {
    margin-bottom: 12px;
  }
  
  .dm-search-section-title {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-3);
    margin-bottom: 8px;
  }
  
  .dm-search-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 12px;
    border-radius: 6px;
    font-size: 14px;
    transition: background 0.15s;
  }
  
  .dm-search-item:hover {
    background: var(--paper-2);
  }
  
  .dm-search-item-sku {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
  }
  
  .dm-search-empty {
    padding: 8px 12px;
    color: var(--ink-3);
    font-size: 13px;
  }
</style>
