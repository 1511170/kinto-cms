---
import { getStorefrontCollections, isShopifyCollection, collectionHref } from '../lib/shopify-catalog';
const collections = await getStorefrontCollections();
---
<footer class="dm-footer">
  <div class="dm-footer-grid">
    <div class="dm-footer-brand"><div class="dm-logo-mark dm-logo-mark--lg"><span>DM</span></div><div class="dm-footer-name">Distribuidor Miranda</div><p>Importadores directos de repuestos de colisión para el mercado ecuatoriano desde 1996. Atendemos mayoristas, talleres y aseguradoras.</p><div class="dm-footer-cert"><span class="mono">RUC 1791234567001</span><span class="mono">SRI · Contribuyente especial</span></div></div>
    <div><h5>Catálogo</h5><ul>{collections.slice(0, 6).map(c => <li><a href={collectionHref(c)}>{isShopifyCollection(c) ? c.title : c.label}</a></li>)}</ul></div>
    <div><h5>Servicio</h5><ul><li><a href="/contacto/">Cotizar por VIN/foto</a></li><li><a href="/preguntas-frecuentes/">Preguntas frecuentes</a></li><li><a href="/sobre-distribuidor-miranda/">Sobre Distribuidor Miranda</a></li><li><a href="/llms-full.txt">Referencia para IA</a></li></ul></div>
    <div><h5>Marcas</h5><ul><li><a href="/repuestos/chevrolet/">Repuestos Chevrolet</a></li><li><a href="/repuestos/hyundai/">Repuestos Hyundai</a></li><li><a href="/repuestos/kia/">Repuestos Kia</a></li><li><a href="/repuestos/toyota/">Repuestos Toyota</a></li><li><a href="/repuestos/nissan/">Repuestos Nissan</a></li></ul></div>
    <div><h5>Sucursales</h5><ul class="dm-footer-locs"><li><strong>Quito · Matriz</strong><span>Av. Galo Plaza Lasso N62-104</span></li><li><strong>Guayaquil</strong><span>Km 8.5 Vía Daule</span></li><li><strong>Cuenca</strong><span>Av. de las Américas</span></li></ul></div>
    <div><h5>Boletín mayorista</h5><p>Recibe lista de precios y nuevos arribos.</p><form class="dm-news-form"><input type="email" placeholder="correo@empresa.com" /><button>Suscribir</button></form><div class="dm-pays"><span>Visa</span><span>Mastercard</span><span>Transfer</span></div></div>
  </div>
  <div class="dm-footer-base"><span>© 2026 Distribuidor Miranda Cía. Ltda.</span><span class="spacer"></span><a href="/catalogo/todos/">Términos</a><a href="/catalogo/todos/">Privacidad</a></div>
</footer>
