---
// StockBadge.astro - Badge de disponibilidad
interface Props {
  available: boolean;
  quantity?: number;
  lowStockThreshold?: number;
}

const { available, quantity = 0, lowStockThreshold = 5 } = Astro.props;

let status: 'in-stock' | 'low-stock' | 'out-of-stock' = 'out-of-stock';
let label = 'Agotado';

if (available) {
  if (quantity > lowStockThreshold) {
    status = 'in-stock';
    label = 'En stock';
  } else if (quantity > 0) {
    status = 'low-stock';
    label = `Solo ${quantity} disponibles`;
  } else {
    status = 'in-stock';
    label = 'Disponible';
  }
}
---

<span class:list={['dm-stock-badge', `dm-stock-badge--${status}`]}>
  <span class="dm-stock-dot"></span>
  {label}
</span>

<style>
  .dm-stock-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
  }
  
  .dm-stock-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: currentColor;
  }
  
  .dm-stock-badge--in-stock {
    color: var(--good, #22c55e);
  }
  
  .dm-stock-badge--low-stock {
    color: #f59e0b;
  }
  
  .dm-stock-badge--out-of-stock {
    color: var(--danger, #ef4444);
  }
</style>
