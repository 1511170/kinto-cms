---
import PartPlaceholder from './PartPlaceholder.astro';
import StockBadge from './StockBadge.astro';
import QuickView from './QuickView.astro';
import siteConfig from '../../config/site.config';
import { buildWhatsappUrl } from '@skills-community/whatsapp-cta/lib/whatsapp-ga4';
import { formatPrice as formatLocalPrice, type Product as LocalProduct } from '../data/catalog';
import { isShopifyProduct, productHref, productAvailable, productImage, productImageUrl, productKey, productPlaceholder, productSku, productTitle, productPartBrand, type Product as ShopifyProduct } from '../lib/shopify-catalog';

export type ProductCardProps = {
  product: ShopifyProduct | LocalProduct;
};

const { product } = Astro.props as ProductCardProps;

const isShopify = isShopifyProduct(product);
const title = productTitle(product);
const variant = isShopify && product.variants?.[0] ? product.variants[0] : undefined;
const price = isShopify ? Number(variant?.price?.amount ?? 0) : product.price;
const image = productImage(product);
const image640 = productImageUrl(product, 640);
const image320 = productImageUrl(product, 320);
const image960 = productImageUrl(product, 960);
const href = isShopify ? productHref(product) : `/producto/${product.code}/`;
const sku = productSku(product);
const key = productKey(product);
const available = productAvailable(product);
const partBrand = productPartBrand(product);
const productBrand = partBrand.name;
const productCategory = isShopify ? (product.productType || product.collections?.[0] || 'Repuesto') : product.catLabel;
const compareAtPrice = isShopify ? Number(variant?.compareAtPrice?.amount ?? 0) || undefined : undefined;
const formattedPrice = isShopify
  ? (price > 0 ? `$${price.toFixed(2)}` : 'Consultar')
  : formatLocalPrice(product.price);
const placeholder = productPlaceholder(product);
const productUrl = `https://${siteConfig.site.domain}${href}`;
const whatsappMessage = siteConfig.contact.whatsappProductMessage
  .replace('{name}', title)
  .replace('{sku}', sku)
  .replace('{url}', productUrl);
const whatsappHref = buildWhatsappUrl(siteConfig.contact.whatsappPhone, whatsappMessage);
const whatsappPayload = {
  click_location: 'product_card',
  item_id: sku,
  item_name: title,
  item_brand: productBrand,
  item_category: productCategory,
  product_url: productUrl,
};
---

<article
  class={`dm-card dm-product-card ${!available ? 'is-sold-out' : ''}`}
  data-product-id={key}
  data-product-name={title}
  data-product-sku={sku}
  data-product-brand={productBrand}
  data-product-category={productCategory}
  data-product-price={price > 0 ? price.toFixed(2) : ''}
>
  <a href={href} class={`dm-card-media ${image640 ? 'has-real-image' : 'has-placeholder'}`}>
    {image640 ? (
      <>
        <img
          src={image640}
          srcset={`${image320} 320w, ${image640} 640w, ${image960} 960w`}
          sizes="(max-width: 720px) 92vw, (max-width: 1100px) 45vw, 25vw"
          width={image?.width ?? 640}
          height={image?.height ?? 640}
          alt={image?.altText || title}
          loading="lazy"
          decoding="async"
          fetchpriority="low"
          onerror="this.style.display='none'; this.nextElementSibling.hidden=false;"
        />
        <div class="dm-image-fallback" hidden>
          <PartPlaceholder code={placeholder.code} label={placeholder.label} accent={placeholder.accent} size="lg" />
        </div>
      </>
    ) : (
      <PartPlaceholder code={placeholder.code} label={placeholder.label} accent={placeholder.accent} size="lg" />
    )}
    
    {!available && <span class="dm-badge dm-badge--soldout">Agotado</span>}
    {compareAtPrice && compareAtPrice > price && <span class="dm-badge dm-badge--sale">-{Math.round((1 - price/compareAtPrice) * 100)}%</span>}
    
    <button class="dm-quickview-btn" data-quickview-trigger={key} type="button" aria-label="Vista rápida">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    </button>
  </a>
  
  <div class="dm-card-body">
    <div class="dm-card-sku mono">{sku}</div>
    <h3 class="dm-card-title">
      <a href={href}>{title}</a>
    </h3>
    
    <div class="dm-card-meta">
      <span class="dm-card-brand"><span class="mono">{partBrand.code}</span> {productBrand}</span>
      <StockBadge available={available} />
    </div>
    
    <div class="dm-card-price">
      <span class="dm-card-price-now">{formattedPrice}</span>
      {compareAtPrice && compareAtPrice > price && (
        <span class="dm-card-price-compare">${compareAtPrice.toFixed(2)}</span>
      )}
    </div>
    
    <div class="dm-card-actions">
      {available ? (
        <>
          <button class="dm-btn dm-btn-primary dm-btn-full" data-add-to-cart data-variant-id={variant?.id ?? ''}>
            Agregar al carrito
          </button>
          <a class="dm-btn dm-btn-outline dm-btn-full dm-btn-whatsapp-card" href={whatsappHref} target="_blank" rel="noopener noreferrer" data-wa-cta data-wa-event="whatsapp_click_product" data-wa-phone={siteConfig.contact.whatsappPhone} data-wa-payload={JSON.stringify(whatsappPayload)}>
            Cotizar por WhatsApp
          </a>
        </>
      ) : (
        <a class="dm-btn dm-btn-outline dm-btn-full dm-btn-whatsapp-card" href={whatsappHref} target="_blank" rel="noopener noreferrer" data-wa-cta data-wa-event="whatsapp_click_product" data-wa-phone={siteConfig.contact.whatsappPhone} data-wa-payload={JSON.stringify(whatsappPayload)}>
          Cotizar disponibilidad
        </a>
      )}
    </div>
  </div>
</article>

{isShopify && <QuickView product={product} productKey={key} />}

<style>
  .dm-product-card {
    display: flex;
    flex-direction: column;
    background: var(--surface, #fff);
    border: 1px solid var(--line, #ddd);
    border-radius: 12px;
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  
  .dm-product-card:hover {
    box-shadow: var(--shadow, 0 4px 12px rgba(0,0,0,0.1));
    transform: translateY(-2px);
  }
  
  .dm-card-media {
    position: relative;
    aspect-ratio: 1;
    background: linear-gradient(180deg, var(--surface-2, #fbf8f1), var(--paper, #f5f5f5));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  
  .dm-card-media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 14px;
    transition: transform 0.3s, opacity 0.2s;
  }
  
  .dm-product-card:hover .dm-card-media img {
    transform: scale(1.04);
  }

  .dm-image-fallback {
    width: 100%;
    height: 100%;
  }

  .dm-product-card.is-sold-out {
    opacity: 0.82;
  }
  
  .dm-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  
  .dm-badge--soldout {
    background: var(--danger, #ef4444);
    color: #fff;
  }
  
  .dm-badge--sale {
    background: var(--accent, #f59e0b);
    color: #fff;
  }
  
  .dm-quickview-btn {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--line, #ddd);
    background: rgba(255, 255, 255, 0.9);
    display: grid;
    place-items: center;
    opacity: 0;
    transition: opacity 0.2s;
    cursor: pointer;
  }
  
  .dm-product-card:hover .dm-quickview-btn {
    opacity: 1;
  }
  
  .dm-card-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }
  
  .dm-card-sku {
    font-size: 11px;
    color: var(--ink-3, #666);
    text-transform: uppercase;
  }
  
  .dm-card-title {
    font-family: var(--font-display, system-ui);
    font-size: 15px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 58px;
  }
  
  .dm-card-title a {
    color: inherit;
  }
  
  .dm-card-title a:hover {
    color: var(--accent, #f59e0b);
  }
  
  .dm-card-meta {
    margin-top: auto;
  }
  
  .dm-card-price {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  
  .dm-card-price-now {
    font-size: 18px;
    font-weight: 800;
    color: var(--accent, #f59e0b);
  }
  
  .dm-card-price-compare {
    font-size: 14px;
    color: var(--ink-3, #666);
    text-decoration: line-through;
  }
  
  .dm-card-actions {
    margin-top: 4px;
    display: grid;
    gap: 8px;
  }
  
  .dm-card-actions .dm-btn {
    height: 40px;
    font-size: 13px;
  }

  .dm-btn-whatsapp-card {
    border-color: rgba(37, 211, 102, 0.55);
    color: #128c4a;
    background: rgba(37, 211, 102, 0.08);
  }

  .dm-btn-whatsapp-card:hover {
    background: #25d366;
    border-color: #25d366;
    color: #fff;
  }

  @media (hover: none) {
    .dm-quickview-btn { opacity: 1; }
  }
</style>

<script>
  // Quick view trigger
  document.querySelectorAll('[data-quickview-trigger]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const id = btn.getAttribute('data-quickview-trigger');
      const modal = document.querySelector(`[data-quickview="${id}"]`);
      if (modal) modal.hidden = false;
    });
  });

  // Add-to-cart is owned globally by CartDrawer. Product cards only expose
  // data-add-to-cart/data-variant-id so product pages and listings behave alike.
</script>
