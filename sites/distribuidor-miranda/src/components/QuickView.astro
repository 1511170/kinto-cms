---
// QuickView.astro - Vista rápida de producto en modal
import { productAvailable, productHref, productImageUrl, productKey as getProductKey, productPlaceholder, productSku, type Product } from '../lib/shopify-catalog';
import PartPlaceholder from './PartPlaceholder.astro';
import StockBadge from './StockBadge.astro';
import siteConfig from '../../config/site.config';
import { buildWhatsappUrl } from '@skills-community/whatsapp-cta/lib/whatsapp-ga4';

interface Props {
  product: Product;
  productKey?: string;
}

const { product, productKey: providedProductKey } = Astro.props;
const variant = product.variants?.[0];
const price = Number(variant?.price?.amount ?? 0);
const compareAtPrice = Number(variant?.compareAtPrice?.amount ?? 0) || undefined;
const available = productAvailable(product);
const sku = productSku(product);
const imageUrl = productImageUrl(product, 720);
const modalKey = providedProductKey || getProductKey(product);
const placeholder = productPlaceholder(product);
const href = productHref(product);
const productUrl = `https://${siteConfig.site.domain}${href}`;
const productCategory = product.productType || product.collections?.[0] || 'Repuesto';
const whatsappMessage = siteConfig.contact.whatsappProductMessage
  .replace('{name}', product.title)
  .replace('{sku}', sku)
  .replace('{url}', productUrl);
const whatsappHref = buildWhatsappUrl(siteConfig.contact.whatsappPhone, whatsappMessage);
const whatsappPayload = {
  click_location: 'quick_view',
  item_id: sku,
  item_name: product.title,
  item_brand: product.vendor || '',
  item_category: productCategory,
  product_url: productUrl,
};
---

<div class="dm-quickview" data-quickview={modalKey} hidden>
  <div class="dm-quickview-overlay"></div>
  <div class="dm-quickview-content">
    <button class="dm-quickview-close" aria-label="Cerrar">×</button>
    
    <div class="dm-quickview-grid">
      <div class="dm-quickview-image">
        {imageUrl ? (
          <img src={imageUrl} alt={product.title} loading="lazy" decoding="async" onerror="this.style.display='none';" />
        ) : (
          <PartPlaceholder code={placeholder.code} label={placeholder.label} accent={placeholder.accent} size="lg" />
        )}
      </div>
      
      <div class="dm-quickview-info">
        <div class="dm-quickview-sku mono">{sku}</div>
        <h3 class="dm-quickview-title">{product.title}</h3>
        
        <div class="dm-quickview-price">
          <span class="dm-quickview-price-now">{price > 0 ? `$${price.toFixed(2)}` : 'Cotizar'}</span>
          {compareAtPrice && compareAtPrice > price && (
            <span class="dm-quickview-price-compare">${compareAtPrice.toFixed(2)}</span>
          )}
        </div>
        
        <StockBadge available={available} />
        
        <p class="dm-quickview-desc">{product.description || 'Repuesto original y alternativo para vehículos.'}</p>
        
        <div class="dm-quickview-actions">
          <a href={href} class="dm-btn dm-btn-primary dm-btn-full">
            Ver detalles →
          </a>
          <a href={whatsappHref} class="dm-btn dm-btn-outline dm-btn-full dm-quickview-whatsapp" target="_blank" rel="noopener noreferrer" data-wa-cta data-wa-event="whatsapp_click_product" data-wa-phone={siteConfig.contact.whatsappPhone} data-wa-payload={JSON.stringify(whatsappPayload)}>
            Consultar por WhatsApp
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .dm-quickview {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  
  .dm-quickview[hidden] {
    display: none;
  }
  
  .dm-quickview-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }
  
  .dm-quickview-content {
    position: relative;
    background: var(--surface, #fff);
    border-radius: 16px;
    max-width: 800px;
    width: 100%;
    max-height: 90vh;
    overflow: auto;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }
  
  .dm-quickview-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--line, #ddd);
    background: var(--surface, #fff);
    font-size: 20px;
    cursor: pointer;
    z-index: 10;
  }
  
  .dm-quickview-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }
  
  .dm-quickview-image {
    aspect-ratio: 1;
    background: var(--paper, #f5f5f5);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .dm-quickview-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 24px;
  }
  
  .dm-quickview-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    color: var(--ink-3, #666);
  }
  
  .dm-quickview-info {
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  
  .dm-quickview-sku {
    font-size: 11px;
    color: var(--ink-3, #666);
    text-transform: uppercase;
  }
  
  .dm-quickview-title {
    font-family: var(--font-display, system-ui);
    font-size: 24px;
    font-weight: 800;
    line-height: 1.2;
    margin: 0;
  }
  
  .dm-quickview-price {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  
  .dm-quickview-price-now {
    font-size: 28px;
    font-weight: 800;
    color: var(--accent, #f59e0b);
  }
  
  .dm-quickview-price-compare {
    font-size: 18px;
    color: var(--ink-3, #666);
    text-decoration: line-through;
  }
  
  .dm-quickview-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-2, #333);
    margin: 0;
  }
  
  .dm-quickview-actions {
    margin-top: auto;
    padding-top: 16px;
    display: grid;
    gap: 10px;
  }

  .dm-quickview-whatsapp {
    border-color: rgba(37, 211, 102, 0.55);
    color: #128c4a;
    background: rgba(37, 211, 102, 0.08);
  }

  .dm-quickview-whatsapp:hover {
    background: #25d366;
    border-color: #25d366;
    color: #fff;
  }
  
  @media (max-width: 640px) {
    .dm-quickview-grid {
      grid-template-columns: 1fr;
    }
    
    .dm-quickview-image {
      aspect-ratio: 16/9;
    }
  }
</style>
