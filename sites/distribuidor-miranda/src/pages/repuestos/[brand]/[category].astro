---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ProductCard from '../../../components/ProductCard.astro';
import { getStorefrontProducts } from '../../../lib/shopify-catalog';
import { absoluteUrl, breadcrumbSchema, collectionSchema, faqSchema, jsonLd } from '../../../lib/seo';
import {
  SEO_BRANDS,
  SEO_PART_CATEGORIES,
  brandCategoryDescription,
  brandCategoryHref,
  brandCategoryTitle,
  brandHref,
  buildBrandCategoryRoutes,
  landingFaqs,
  topAvailableProducts,
} from '../../../lib/seo-landings';

export async function getStaticPaths() {
  const products = await getStorefrontProducts();
  return buildBrandCategoryRoutes(products).map((route) => ({
    params: { brand: route.brand.slug, category: route.category.slug },
    props: route,
  }));
}

const { brand, category, products } = Astro.props;
const visibleProducts = topAvailableProducts(products, 36);
const title = brandCategoryTitle(brand, category);
const description = brandCategoryDescription(brand, category, products.length);
const canonical = absoluteUrl(brandCategoryHref(brand, category));
const faqs = landingFaqs(brand, category);
const siblingCategories = SEO_PART_CATEGORIES.filter((item) => item.slug !== category.slug).slice(0, 7);
const siblingBrands = SEO_BRANDS.filter((item) => item.slug !== brand.slug).slice(0, 8);
const schemas = [
  collectionSchema({ name: title, description, url: brandCategoryHref(brand, category), products: visibleProducts }),
  breadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Repuestos', url: '/catalogo/todos/' },
    { name: brand.name, url: brandHref(brand) },
    { name: category.name, url: brandCategoryHref(brand, category) },
  ]),
  faqSchema(faqs),
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    {schemas.map((schema) => <script type="application/ld+json" set:html={jsonLd(schema)} />)}
  </Fragment>
  <Header />
  <main class="dm-seo-landing">
    <section class="dm-landing-hero section">
      <div class="container">
        <p class="eyebrow">Landing comercial por marca y categoría</p>
        <h1>{title}</h1>
        <p class="lead">{description}</p>
        <div class="dm-landing-actions">
          <a class="dm-btn dm-btn-primary" href={`https://wa.me/593996140000?text=${encodeURIComponent(`Hola, necesito cotizar ${category.plural} ${brand.name}.`)}`} target="_blank" rel="noopener">Cotizar {category.name}</a>
          <a class="dm-btn dm-btn-outline" href={brandHref(brand)}>Ver todo {brand.name}</a>
        </div>
        <div class="dm-proof-grid">
          <span>{products.length.toLocaleString('es-EC')} referencias filtradas</span>
          <span>Compatibilidad por año, lado y versión</span>
          <span>Catálogo Ecuador</span>
        </div>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container">
        <div class="section-head">
          <div>
            <p class="eyebrow">Productos relevantes</p>
            <h2>{category.name} {brand.name} para cotizar</h2>
          </div>
          <a href="/contacto/">Pedir ayuda →</a>
        </div>
        <div class="dm-product-grid">
          {visibleProducts.map((product) => <ProductCard product={product} />)}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container dm-copy-block">
        <h2>Guía rápida para comprar {category.plural} {brand.name}</h2>
        <p>Antes de comprar {category.plural} {brand.name}, confirma que la pieza corresponda al modelo, año, versión y lado correcto. En repuestos de {category.intent}, pequeñas variaciones pueden cambiar puntos de anclaje, conectores, forma o acabado.</p>
        <p>Distribuidor Miranda atiende consultas con foto, VIN, código de pieza o referencia del catálogo para validar disponibilidad y compatibilidad antes del despacho.</p>
        <ul>
          <li>Usa la foto del repuesto instalado o dañado para comparar forma y anclajes.</li>
          <li>Confirma si necesitas lado izquierdo/LH o derecho/RH.</li>
          <li>Pregunta por alternativas originales, genuinas o equivalentes cuando aplique.</li>
        </ul>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container">
        <h2>Más búsquedas relacionadas</h2>
        <div class="dm-link-grid">
          {siblingCategories.map((item) => (
            <a href={brandCategoryHref(brand, item)}><strong>{item.name} {brand.name}</strong><span>Ver categoría</span></a>
          ))}
          {siblingBrands.map((item) => (
            <a href={brandCategoryHref(item, category)}><strong>{category.name} {item.name}</strong><span>Comparar otra marca</span></a>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container dm-faq-list">
        <h2>Preguntas frecuentes</h2>
        {faqs.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .dm-seo-landing .dm-landing-hero { background: linear-gradient(135deg, #23180b, var(--ink,#1f2937)); color: white; }
  .dm-seo-landing h1 { font-size: clamp(2.1rem, 5vw, 4.4rem); line-height: .98; max-width: 960px; margin: 0 0 1rem; }
  .dm-seo-landing .lead { max-width: 880px; font-size: 1.12rem; color: rgba(255,255,255,.86); }
  .dm-landing-actions { display: flex; gap: .75rem; flex-wrap: wrap; margin: 1.5rem 0; }
  .dm-proof-grid { display: flex; gap: .75rem; flex-wrap: wrap; margin-top: 1rem; }
  .dm-proof-grid span { border: 1px solid rgba(255,255,255,.22); border-radius: 999px; padding: .55rem .85rem; background: rgba(255,255,255,.08); }
  .section-alt { background: var(--surface-2,#fbf8f1); }
  .section-head { display:flex; align-items:end; justify-content:space-between; gap:1rem; margin-bottom:1rem; }
  .dm-product-grid { display:grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem; }
  .dm-copy-block { max-width: 920px; }
  .dm-copy-block li { margin: .4rem 0; }
  .dm-link-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px,1fr)); gap: .8rem; }
  .dm-link-grid a { border: 1px solid var(--line,#ddd); border-radius: 14px; padding: 1rem; background: var(--surface,#fff); display: grid; gap: .3rem; }
  .dm-link-grid span { color: var(--ink-3,#666); font-size: .9rem; }
  .dm-faq-list { max-width: 900px; }
  .dm-faq-list details { border: 1px solid var(--line,#ddd); border-radius: 12px; padding: 1rem; background: var(--surface,#fff); margin: .75rem 0; }
  .dm-faq-list summary { font-weight: 800; cursor: pointer; }
</style>
