---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PartPlaceholder from '../components/PartPlaceholder.astro';
import ProductCard from '../components/ProductCard.astro';
import { VEHICLE_MAKES, PARTNER_BRANDS } from '../data/catalog';
import {
  getStorefrontProducts,
  getStorefrontCollections,
  collectionHref,
  isShopifyCollection,
  isShopifyProduct,
  productHref,
  productImage,
  productImageUrl,
  productSku,
  productTitle,
} from '../lib/shopify-catalog';
import { businessSchemas, jsonLd, breadcrumbSchema } from '../lib/seo';

const [allProducts, collections] = await Promise.all([
  getStorefrontProducts(),
  getStorefrontCollections(),
]);

// En home mostramos primero productos con foto real: los placeholders quedan para catálogo/detalle,
// no para la primera impresión del sitio.
const productsWithPhotos = allProducts.filter((product) => productImage(product));
const homeProducts = productsWithPhotos.length >= 24 ? productsWithPhotos : allProducts;
const featured = homeProducts.slice(0, 8);
const newest = homeProducts.slice(8, 16);
const popular = homeProducts.slice(16, 24);

const findHeroProduct = (pattern: RegExp, offset = 0) =>
  productsWithPhotos.find((product, index) => index >= offset && pattern.test(productTitle(product).toLowerCase())) ?? productsWithPhotos[offset];

const heroProducts = [
  findHeroProduct(/silvin|faro|neblin|lamp|luz|guardachoque|parachoque|capot|guardafango/, 0),
  findHeroProduct(/radiador|refriger|manguera|ventilador|condensador/, 1),
  findHeroProduct(/zapatas|freno|amort|terminal|bomba|sensor|manilla/, 2),
].filter(Boolean);

const collectionImageUrl = (collection: (typeof collections)[number], width = 720) => {
  if (isShopifyCollection(collection) && collection.image?.url) {
    try {
      const url = new URL(collection.image.url);
      url.searchParams.set('width', String(width));
      return url.toString();
    } catch {
      return collection.image.url;
    }
  }

  if (isShopifyCollection(collection)) {
    const match = productsWithPhotos.find((product) => isShopifyProduct(product) && product.collections?.includes(collection.handle));
    return match ? productImageUrl(match, width) : '';
  }

  return '';
};

const categoryBlurb = (collection: (typeof collections)[number]) => {
  const title = (isShopifyCollection(collection) ? collection.title : collection.label).toLowerCase();
  if (/espejo/.test(title)) return 'Retrovisores, vidrios, tapas y bases laterales por modelo.';
  if (/guardachoque|parachoque/.test(title)) return 'Guardachoques delanteros/posteriores, vinchas, absorbedores y soportes.';
  if (/radiador/.test(title)) return 'Radiadores, electroventiladores, tapas, bases y refrigeración.';
  if (/silvin|faro|neblin/.test(title)) return 'Silvines, faros, neblineros, focos y accesorios de iluminación.';
  if (/capot/.test(title)) return 'Capots, bisagras, seguros y componentes frontales de carrocería.';
  if (/todos/.test(title)) return 'Explora todo el inventario disponible por código, marca o modelo.';
  return isShopifyCollection(collection)
    ? (collection.description || 'Repuestos seleccionados para despacho nacional.')
    : collection.blurb;
};

const homeSchemas = [
  ...businessSchemas(),
  breadcrumbSchema([{ name: 'Inicio', url: '/' }]),
];
---
<Layout title="Distribuidor Miranda" description="Repuestos de colisión, iluminación y refrigeración para talleres, mayoristas y aseguradoras en Ecuador.">
  <Fragment slot="head">
    {homeSchemas.map((schema) => <script type="application/ld+json" set:html={jsonLd(schema)} />)}
  </Fragment>
  <Header />
  <main class="dm-main dm-home">
    <!-- Hero Section -->
    <section class="dm-hero">
      <div class="dm-hero-grid">
        <div class="dm-hero-left">
          <div class="dm-eyebrow"><span class="dm-eyebrow-dot"></span>CATÁLOGO DE AUTOPARTES · ECUADOR</div>
          <h1 class="dm-hero-title">Repuestos de<br/><em>colisión</em> listos<br/>para despacho.</h1>
          <p class="dm-hero-sub">Guardachoques, silvines, radiadores, capots, guardafangos, manillas y piezas de alta rotación para talleres, aseguradoras y mayoristas. Compra por modelo, código o disponibilidad real.</p>
          
          <!-- Buscador por vehículo -->
          <form class="dm-finder" id="vehicle-finder" action="/catalogo/todos/">
            <div class="dm-finder-head">▰ Encuentra tu repuesto por vehículo</div>
            <div class="dm-finder-row">
              <select id="make-select" name="make">
                <option value="">Marca</option>
                {VEHICLE_MAKES.map(m => <option value={m}>{m}</option>)}
              </select>
              <select id="model-select" name="model" disabled>
                <option value="">Modelo</option>
              </select>
              <select id="year-select" name="year" disabled>
                <option value="">Año</option>
                {Array.from({ length: 18 }, (_, i) => 2025 - i).map(y => <option value={y}>{y}</option>)}
              </select>
              <button type="submit" class="dm-btn dm-btn-primary" id="finder-search" disabled>Buscar →</button>
            </div>
            <div class="dm-finder-foot">
              <span>O busca por:</span>
              <a href="/catalogo/todos/">VIN</a>
              <a href="/catalogo/todos/">Código OEM</a>
              <a href="/catalogo/todos/">Subir foto del repuesto</a>
            </div>
          </form>
          
          <div class="dm-hero-stats">
            <div><strong>30+</strong><span>años importando</span></div>
            <div><strong>11k+</strong><span>referencias</span></div>
            <div><strong>240+</strong><span>modelos</span></div>
            <div><strong>48h</strong><span>entrega nacional</span></div>
          </div>
        </div>
        <div class="dm-hero-right">
          <div class="dm-hero-stack">
            {heroProducts.map((product, i) => (
              <a class={`dm-hero-card dm-hero-card-${i + 1} dm-hero-product-card`} href={productHref(product)}>
                <img
                  class="dm-hero-product-img"
                  src={productImageUrl(product, i === 0 ? 960 : 640)}
                  alt={productTitle(product)}
                  width="640"
                  height="640"
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                />
                <div class="dm-hero-card-meta">
                  <span class="mono">{productSku(product)}</span>
                  <span>{productTitle(product)}</span>
                </div>
              </a>
            ))}
          </div>
          <div class="dm-hero-blueprint mono">REPUESTOS MIRANDA · STOCK EN LÍNEA</div>
        </div>
      </div>
    </section>

    <!-- Categorías -->
    <section class="dm-cats">
      <div class="dm-section-head">
        <div>
          <div class="dm-section-eyebrow mono">/01 · CATEGORÍAS</div>
          <h2>Compra por tipo de repuesto</h2>
        </div>
        <a class="dm-section-link" href={collections[0] ? collectionHref(collections[0]) : '/catalogo/todos/'}>
          Ver catálogo completo →
        </a>
      </div>
      <div class="dm-cats-grid">
        {collections.slice(0, 6).map((c, i) => (
          <a class="dm-cat-tile" href={collectionHref(c)}>
            <div class="dm-cat-tile-media">
              {collectionImageUrl(c) ? (
                <img
                  class="dm-cat-tile-img"
                  src={collectionImageUrl(c)}
                  alt={isShopifyCollection(c) ? c.title : c.label}
                  width="720"
                  height="520"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <PartPlaceholder
                  code={(isShopifyCollection(c) ? c.title : c.code).slice(0, 3).toUpperCase()}
                  label={(isShopifyCollection(c) ? c.title : c.label).toUpperCase()}
                  accent={['warm','cool','olive','steel','warm','olive'][i]}
                  size="lg"
                />
              )}
            </div>
            <div class="dm-cat-tile-body">
              <div class="dm-cat-tile-count mono">
                {isShopifyCollection(c) && c.productsCount ? `${c.productsCount} productos` : 'Catálogo'}
              </div>
              <div class="dm-cat-tile-name">{isShopifyCollection(c) ? c.title : c.label}</div>
              <div class="dm-cat-tile-blurb">
                {categoryBlurb(c)}
              </div>
              <span class="dm-cat-tile-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Destacados -->
    <section class="dm-feature">
      <div class="dm-section-head">
        <div>
          <div class="dm-section-eyebrow mono">/02 · DESTACADOS</div>
          <h2>Productos más vendidos</h2>
          <p class="dm-section-sub">Repuestos con mayor rotación en talleres y mayoristas.</p>
        </div>
      </div>
      <div class="dm-product-grid">
        {featured.map(p => <ProductCard product={p} />)}
      </div>
    </section>

    <!-- Servicios -->
    <section class="dm-services">
      {[
        { title: 'Entrega 24–48h a todo Ecuador', desc: 'Envíos por counter el mismo día si confirmas antes de las 14:00.' },
        { title: 'Asesoría técnica gratuita', desc: 'Verificamos compatibilidad antes de despachar.' },
        { title: 'Garantía de 90 días', desc: 'Sobre defectos de fábrica en carrocería, iluminación y refrigeración.' },
        { title: 'Cuenta mayorista', desc: 'Precios escalonados, crédito y catálogo descargable mensual.' }
      ].map((service, i) => (
        <div class="dm-service">
          <div class="dm-service-num mono">0{i+1}</div>
          <div>
            <h4>{service.title}</h4>
            <p>{service.desc}</p>
          </div>
        </div>
      ))}
    </section>

    <!-- Marcas -->
    <section class="dm-brands">
      <div class="dm-section-head">
        <div>
          <div class="dm-section-eyebrow mono">/03 · MARCAS QUE DISTRIBUIMOS</div>
          <h2>Importadores directos, sin intermediarios</h2>
        </div>
      </div>
      <div class="dm-brands-grid">
        {PARTNER_BRANDS.map(b => (
          <div class="dm-brand-card">
            <div class="dm-brand-mark mono">{b.name.split(' ')[0].slice(0,4)}</div>
            <div>
              <div class="dm-brand-name">{b.name}</div>
              <div class="dm-brand-tag">{b.tag}</div>
            </div>
            <div class="dm-brand-arrow">→</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Nuevos arribos -->
    <section class="dm-feature">
      <div class="dm-section-head">
        <div>
          <div class="dm-section-eyebrow mono">/04 · NUEVOS ARRIBOS</div>
          <h2>Lo último que llegó a bodega</h2>
          <p class="dm-section-sub">Productos recién ingresados al inventario.</p>
        </div>
      </div>
      <div class="dm-product-grid">
        {newest.map(p => <ProductCard product={p} />)}
      </div>
    </section>

    <!-- Populares -->
    <section class="dm-feature">
      <div class="dm-section-head">
        <div>
          <div class="dm-section-eyebrow mono">/05 · MÁS BUSCADOS</div>
          <h2>Productos más consultados</h2>
          <p class="dm-section-sub">Lo que otros clientes están viendo ahora.</p>
        </div>
      </div>
      <div class="dm-product-grid">
        {popular.map(p => <ProductCard product={p} />)}
      </div>
    </section>

    <!-- CTA Mayoristas -->
    <section class="dm-cta" id="mayoristas">
      <div class="dm-cta-inner">
        <div>
          <div class="dm-eyebrow dm-eyebrow-light">
            <span class="dm-eyebrow-dot"></span>
            PROGRAMA MAYORISTA · MIRANDA TRADE
          </div>
          <h2>¿Tienes un taller o concesionario?<br/>Hagamos negocio.</h2>
          <p>Precios escalonados, crédito 30 días previa calificación, despacho consolidado semanal y catálogo PDF actualizado.</p>
        </div>
        <a class="dm-btn dm-btn-light" href="mailto:ventas@distribuidormiranda.ec">Solicitar lista de precios</a>
      </div>
    </section>
  </main>
  <Footer />

  <!-- Script para el buscador por vehículo -->
  <script>
    // Datos de modelos por marca (esto debería venir de una API o archivo JSON)
    const vehicleModels = {
      'Toyota': ['Hilux', 'Corolla', 'Yaris', 'RAV4', 'Fortuner', 'Prado', 'Land Cruiser'],
      'Chevrolet': ['Aveo', 'Sail', 'Spark', 'D-Max', 'LUV', 'Grand Vitara', 'Tracker'],
      'Nissan': ['Sentra', 'Versa', 'X-Trail', 'Frontier', 'Navara', 'Tiida', 'Qashqai'],
      'Hyundai': ['Accent', 'Tucson', 'Santa Fe', 'Elantra', 'i10', 'i30', 'Creta'],
      'Kia': ['Rio', 'Sportage', 'Sorento', 'Picanto', 'Cerato', 'Seltos', 'Soluto'],
      'Mazda': ['BT-50', '3', '6', 'CX-5', 'CX-9', '2', 'B2200'],
      'Ford': ['Ranger', 'Escape', 'Explorer', 'F-150', 'Focus', 'Fusion', 'Edge'],
      'Volkswagen': ['Amarok', 'Golf', 'Jetta', 'Polo', 'Tiguan', 'Passat', 'Vento'],
      'Renault': ['Logan', 'Sandero', 'Duster', 'Koleos', 'Captur', 'Clio', 'Symbol'],
      'Chery': ['Tiggo', 'Arrizo', 'QQ', 'Orinoco', 'X1', 'Tiggo 2', 'Tiggo 7'],
      'Great Wall': ['Wingle', 'Haval', 'Steed', 'Voleex', 'Florid', 'C30', 'Poer'],
      'Suzuki': ['Swift', 'Vitara', 'Grand Vitara', 'S-Cross', 'Jimny', 'Celerio'],
      'Mitsubishi': ['L200', 'Montero', 'Outlander', 'ASX', 'Mirage', 'Pajero'],
      'Honda': ['Civic', 'CR-V', 'Accord', 'Pilot', 'HR-V', 'Fit', 'City'],
      'JAC': ['J2', 'J3', 'J4', 'S2', 'S3', 'T6', 'T8'],
      'DFSK': ['Glory', 'Cityvan', 'C37', 'K-Series', 'V-Series'],
      'BYD': ['F0', 'F3', 'S6', 'Tang', 'Song', 'Yuan'],
      'MG': ['ZS', 'RX5', 'HS', '5', 'GT', '3'],
    };

    const makeSelect = document.getElementById('make-select');
    const modelSelect = document.getElementById('model-select');
    const yearSelect = document.getElementById('year-select');
    const searchBtn = document.getElementById('finder-search');

    makeSelect.addEventListener('change', (e) => {
      const make = e.target.value;
      modelSelect.innerHTML = '<option value="">Modelo</option>';
      yearSelect.innerHTML = '<option value="">Año</option>';
      yearSelect.disabled = true;
      searchBtn.disabled = true;

      if (make && vehicleModels[make]) {
        vehicleModels[make].forEach(model => {
          const option = document.createElement('option');
          option.value = model;
          option.textContent = model;
          modelSelect.appendChild(option);
        });
        modelSelect.disabled = false;
      } else {
        modelSelect.disabled = true;
      }
    });

    modelSelect.addEventListener('change', (e) => {
      if (e.target.value) {
        yearSelect.disabled = false;
      } else {
        yearSelect.disabled = true;
        searchBtn.disabled = true;
      }
    });

    yearSelect.addEventListener('change', (e) => {
      searchBtn.disabled = !e.target.value;
    });

    document.getElementById('vehicle-finder').addEventListener('submit', (e) => {
      e.preventDefault();
      const make = makeSelect.value;
      const model = modelSelect.value;
      const year = yearSelect.value;
      if (make && model && year) {
        window.location.href = `/catalogo/todos/?make=${encodeURIComponent(make)}&model=${encodeURIComponent(model)}&year=${year}`;
      }
    });
  </script>
</Layout>
