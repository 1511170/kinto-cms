---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { breadcrumbSchema, faqSchema, jsonLd } from '../lib/seo';

const title = 'Preguntas frecuentes sobre repuestos automotrices';
const description = 'Preguntas frecuentes de Distribuidor Miranda sobre compra, cotización, compatibilidad, despacho y búsqueda de repuestos automotrices en Ecuador.';
const faqs = [
  {
    question: '¿Cómo puedo buscar un repuesto en Distribuidor Miranda?',
    answer: 'Puedes buscar por nombre de pieza, SKU, código OEM, marca del vehículo, modelo, año, lado o categoría dentro del catálogo web de Distribuidor Miranda.',
  },
  {
    question: '¿Distribuidor Miranda despacha repuestos a todo Ecuador?',
    answer: 'Sí. Distribuidor Miranda atiende solicitudes para Quito, Guayaquil, Cuenca y provincias, con despacho nacional según disponibilidad, destino y tipo de repuesto.',
  },
  {
    question: '¿Qué datos debo enviar para confirmar compatibilidad?',
    answer: 'Lo ideal es enviar marca, modelo, año, nombre de la pieza, lado o posición, código OEM/SKU si lo tienes y una foto del repuesto o del vehículo.',
  },
  {
    question: '¿Venden a talleres, aseguradoras y mayoristas?',
    answer: 'Sí. El catálogo está pensado para compradores finales, talleres, aseguradoras, flotas y clientes mayoristas que necesitan referencias de alta rotación.',
  },
  {
    question: '¿Qué tipos de repuestos vende Distribuidor Miranda?',
    answer: 'Vende guardachoques, silvines, faros, neblineros, radiadores, capots, guardafangos, espejos, manillas, suspensión, frenos, motor, sensores y otros repuestos automotrices.',
  },
  {
    question: '¿Puedo cotizar si no conozco el código del repuesto?',
    answer: 'Sí. Puedes enviar una foto, los datos del vehículo y una descripción de la pieza para que el equipo ayude a identificar la referencia correcta.',
  },
];
const schemas = [
  faqSchema(faqs),
  breadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Preguntas frecuentes', url: '/preguntas-frecuentes/' },
  ]),
];
---
<Layout title={title} description={description} canonical="https://distribuidormiranda.com.ec/preguntas-frecuentes/">
  <Fragment slot="head">
    {schemas.map((schema) => <script type="application/ld+json" set:html={jsonLd(schema)} />)}
  </Fragment>
  <Header />
  <main class="dm-main dm-home">
    <section class="dm-hero">
      <div class="dm-hero-grid">
        <div class="dm-hero-left">
          <div class="dm-eyebrow"><span class="dm-eyebrow-dot"></span>FAQ · REPUESTOS ECUADOR</div>
          <h1 class="dm-hero-title">Preguntas frecuentes<br/><em>para comprar repuestos</em><br/>en Ecuador.</h1>
          <p class="dm-hero-sub">Respuestas rápidas para buscar, cotizar y confirmar autopartes por código, modelo, año, foto o disponibilidad.</p>
        </div>
      </div>
    </section>

    <section class="dm-feature">
      <div class="dm-section-head"><div><div class="dm-section-eyebrow mono">/ RESPUESTAS</div><h2>Lo más consultado</h2></div></div>
      <div class="dm-cats-grid">
        {faqs.map((faq) => (
          <article class="dm-cat-tile">
            <div class="dm-cat-content">
              <span class="mono">FAQ</span>
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
