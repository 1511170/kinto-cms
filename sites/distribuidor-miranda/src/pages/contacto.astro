---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { breadcrumbSchema, jsonLd, businessSchemas } from '../lib/seo';

const title = 'Contacto Distribuidor Miranda';
const description = 'Contacta a Distribuidor Miranda para comprar o cotizar repuestos automotrices en Ecuador por código, modelo, VIN, foto o disponibilidad.';
const schemas = [
  ...businessSchemas(),
  breadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Contacto', url: '/contacto/' },
  ]),
];
---
<Layout title={title} description={description} canonical="https://distribuidormiranda.com.ec/contacto/">
  <Fragment slot="head">
    {schemas.map((schema) => <script type="application/ld+json" set:html={jsonLd(schema)} />)}
  </Fragment>
  <Header />
  <main class="dm-main dm-home">
    <section class="dm-hero">
      <div class="dm-hero-grid">
        <div class="dm-hero-left">
          <div class="dm-eyebrow"><span class="dm-eyebrow-dot"></span>VENTAS · COTIZACIONES · ECUADOR</div>
          <h1 class="dm-hero-title">Cotiza tu repuesto<br/><em>por código, modelo</em><br/>o foto.</h1>
          <p class="dm-hero-sub">Para confirmar compatibilidad envíanos la marca, modelo, año, código OEM/SKU o una foto del repuesto. Atendemos talleres, aseguradoras, mayoristas y compradores en todo Ecuador.</p>
          <p><a class="dm-btn dm-btn-primary" href="mailto:ventas@distribuidormiranda.com.ec">Enviar correo</a> <a class="dm-btn dm-btn-dark" href="https://wa.me/593996140000">Cotizar por WhatsApp</a></p>
        </div>
        <aside class="dm-aside-card">
          <div class="mono">DATOS PARA COTIZAR MÁS RÁPIDO</div>
          <dl>
            <dt>Vehículo</dt><dd>Marca, modelo y año</dd>
            <dt>Pieza</dt><dd>Nombre del repuesto o foto</dd>
            <dt>Código</dt><dd>SKU, OEM o referencia si la tienes</dd>
            <dt>Lado</dt><dd>Izquierdo/derecho, delantero/posterior</dd>
            <dt>Destino</dt><dd>Ciudad o provincia para despacho</dd>
          </dl>
        </aside>
      </div>
    </section>

    <section class="dm-feature">
      <div class="dm-section-head"><div><div class="dm-section-eyebrow mono">/ CANALES</div><h2>Canales de atención</h2></div></div>
      <div class="dm-cats-grid">
        <article class="dm-cat-tile"><div class="dm-cat-content"><span class="mono">Catálogo</span><h3>Buscar en línea</h3><p>Filtra por código, categoría, disponibilidad, imagen, marca de vehículo y tipo de pieza.</p><a href="/catalogo/todos/">Ir al catálogo →</a></div></article>
        <article class="dm-cat-tile"><div class="dm-cat-content"><span class="mono">WhatsApp</span><h3>Cotización asistida</h3><p>Ideal para validar compatibilidad por foto, VIN, código OEM o número de parte.</p><a href="https://wa.me/593996140000">Abrir WhatsApp →</a></div></article>
        <article class="dm-cat-tile"><div class="dm-cat-content"><span class="mono">Email</span><h3>Ventas</h3><p>Envía listas de repuestos para taller, aseguradora o compra mayorista.</p><a href="mailto:ventas@distribuidormiranda.com.ec">ventas@distribuidormiranda.com.ec</a></div></article>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
