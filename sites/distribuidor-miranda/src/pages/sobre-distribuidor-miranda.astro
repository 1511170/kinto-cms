---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { businessSchemas, breadcrumbSchema, jsonLd } from '../lib/seo';

const title = 'Sobre Distribuidor Miranda';
const description = 'Distribuidor Miranda es un distribuidor de repuestos automotrices en Ecuador especializado en piezas de colisión, iluminación, refrigeración y carrocería para talleres, aseguradoras y mayoristas.';
const schemas = [
  ...businessSchemas(),
  breadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: title, url: '/sobre-distribuidor-miranda/' },
  ]),
];
---
<Layout title={title} description={description} canonical="https://distribuidormiranda.com.ec/sobre-distribuidor-miranda/">
  <Fragment slot="head">
    {schemas.map((schema) => <script type="application/ld+json" set:html={jsonLd(schema)} />)}
  </Fragment>
  <Header />
  <main class="dm-main dm-home">
    <section class="dm-hero">
      <div class="dm-hero-grid">
        <div class="dm-hero-left">
          <div class="dm-eyebrow"><span class="dm-eyebrow-dot"></span>EMPRESA · AUTOPARTES ECUADOR</div>
          <h1 class="dm-hero-title">Distribuidor Miranda:<br/><em>repuestos automotrices</em><br/>para Ecuador.</h1>
          <p class="dm-hero-sub">Desde 1996, Distribuidor Miranda atiende a talleres, mayoristas, aseguradoras y compradores que necesitan repuestos de colisión, carrocería, iluminación, refrigeración, suspensión, frenos y motor con despacho nacional.</p>
          <div class="dm-hero-stats">
            <div><strong>30+</strong><span>años importando</span></div>
            <div><strong>11k+</strong><span>referencias</span></div>
            <div><strong>EC</strong><span>cobertura nacional</span></div>
            <div><strong>48h</strong><span>despacho referencial</span></div>
          </div>
        </div>
        <div class="dm-hero-right">
          <div class="dm-aside-card">
            <div class="mono">ENTIDAD VERIFICABLE</div>
            <dl>
              <dt>Nombre</dt><dd>Distribuidor Miranda</dd>
              <dt>País</dt><dd>Ecuador</dd>
              <dt>Especialidad</dt><dd>Repuestos de colisión y autopartes</dd>
              <dt>Clientes</dt><dd>Talleres, aseguradoras, mayoristas y compradores finales</dd>
              <dt>Canales</dt><dd>Catálogo web, Shopify Checkout y cotización asistida</dd>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <section class="dm-feature">
      <div class="dm-section-head"><div><div class="dm-section-eyebrow mono">/ QUÉ VENDEMOS</div><h2>Autopartes de alta rotación</h2></div></div>
      <div class="dm-cats-grid">
        <article class="dm-cat-tile"><div class="dm-cat-content"><span class="mono">Carrocería</span><h3>Guardachoques, capots y guardafangos</h3><p>Piezas frontales, posteriores y laterales para reparación de colisión.</p></div></article>
        <article class="dm-cat-tile"><div class="dm-cat-content"><span class="mono">Iluminación</span><h3>Silvines, faros, neblineros y focos</h3><p>Componentes de iluminación por código, modelo y lado.</p></div></article>
        <article class="dm-cat-tile"><div class="dm-cat-content"><span class="mono">Refrigeración</span><h3>Radiadores y electroventiladores</h3><p>Repuestos de refrigeración y soporte para mantenimiento correctivo.</p></div></article>
        <article class="dm-cat-tile"><div class="dm-cat-content"><span class="mono">Mecánica</span><h3>Suspensión, frenos, motor y sensores</h3><p>Referencias para talleres y mantenimiento de flotas.</p></div></article>
      </div>
    </section>

    <section class="dm-feature">
      <div class="dm-section-head"><div><div class="dm-section-eyebrow mono">/ COBERTURA</div><h2>Despacho a todo Ecuador</h2></div></div>
      <p class="dm-hero-sub">Atendemos solicitudes de Quito, Guayaquil, Cuenca y provincias. El comprador puede buscar por código OEM/SKU, modelo, año, foto del repuesto o compatibilidad vehicular.</p>
      <p><a class="dm-btn dm-btn-primary" href="/catalogo/todos/">Explorar catálogo</a> <a class="dm-btn dm-btn-outline" href="/contacto/">Contactar ventas</a></p>
    </section>
  </main>
  <Footer />
</Layout>
