---
---

<section class="relative min-h-screen bg-gray-50 overflow-hidden flex items-center pt-16">
  <!-- Blur blobs background (clase .blob del código base) -->
  <div class="blob w-96 h-96 bg-purple-300 rounded-full top-0 left-0 -translate-x-1/2 -translate-y-1/2"></div>
  <div class="blob w-80 h-80 bg-blue-300 rounded-full bottom-0 right-0 translate-x-1/3 translate-y-1/3"></div>

  <div class="relative max-w-7xl mx-auto px-8 py-20 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <!-- Left column -->
    <div class="flex flex-col gap-8">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-5 py-2 bg-brand-100 rounded-full w-fit">
        <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
        </svg>
        <span class="text-brand-600 text-sm font-semibold">Agencia Certificada Internacionalmente</span>
      </div>

      <!-- Headline -->
      <div class="flex flex-col gap-3">
        <h1 class="font-display font-extrabold text-6xl leading-tight text-gray-900">
          Estudia, Trabaja y<br />Vive en el <span class="text-gradient">Exterior</span>
        </h1>
        <p class="font-display font-medium text-2xl text-gray-500">
          Hacemos Tu Sueño Realidad
        </p>
      </div>

      <!-- Body -->
      <p class="text-lg text-gray-500 leading-relaxed max-w-lg">
        Te acompañamos en cada paso de tu aventura internacional.
        Asesoría personalizada, visas aprobadas y soporte en destino.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-4">
        <a
          href="#contacto"
          class="relative inline-flex items-center gap-3 px-7 py-4 bg-brand-600 text-white font-bold rounded-full hover:bg-brand-700 transition-all duration-300 shadow-lg hover:shadow-xl shadow-brand-600/30 transform hover:-translate-y-1"
        >
          <span>Agenda Tu Asesoría<br /><span class="font-extrabold">GRATIS</span></span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a
          href="#testimonios"
          class="inline-flex items-center gap-3 px-7 py-4 bg-white text-gray-700 font-bold rounded-full border border-gray-200 hover:border-brand-300 hover:text-brand-600 transition-all duration-300 shadow-md hover:shadow-lg"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Ver<br />Testimonios</span>
        </a>
      </div>

      <!-- Social proof -->
      <div class="flex items-center gap-6">
        <!-- Avatars -->
        <div class="flex items-center">
          <img src="/images/avatar-1.png" alt="Estudiante" class="w-10 h-10 rounded-full border-2 border-white object-cover" />
          <img src="/images/avatar-2.png" alt="Estudiante" class="w-10 h-10 rounded-full border-2 border-white object-cover -ml-3" />
          <img src="/images/avatar-3.png" alt="Estudiante" class="w-10 h-10 rounded-full border-2 border-white object-cover -ml-3" />
          <div class="w-10 h-10 rounded-full border-2 border-white bg-gray-50 -ml-3 flex items-center justify-center">
            <span class="text-xs font-bold text-gray-600">+500</span>
          </div>
        </div>
        <!-- Rating -->
        <div class="flex flex-col gap-0.5">
          <div class="flex items-center gap-1.5">
            <div class="flex text-yellow-400">
              {Array(5).fill(0).map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="font-bold text-gray-900 text-sm">4.9/5</span>
          </div>
          <span class="text-sm text-gray-500">Estudiantes satisfechos</span>
        </div>
      </div>
    </div>

    <!-- Right column — Hero image + floating cards -->
    <div class="relative">
      <!-- Gradient overlay (primary → secondary como código base) -->
      <div class="absolute inset-0 bg-gradient-to-tr from-brand-600 to-sky-500 rounded-3xl opacity-20 pointer-events-none"></div>

      <!-- Hero image -->
      <div class="relative rounded-3xl overflow-hidden shadow-2xl border-4 border-white border-gray-100">
        <img
          src="/images/hero.png"
          alt="Estudiantes en el exterior"
          class="w-full h-[480px] object-cover"
        />
      </div>

      <!-- Floating card: Tasa de Aprobación (animate-bounce 3s) -->
      <div class="absolute -left-8 top-1/2 -translate-y-1/2 bg-white rounded-2xl shadow-xl border border-gray-100 p-4 flex items-center gap-3 animate-bounce-slow z-10">
        <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 font-medium">Tasa de Aprobación</p>
          <p class="text-lg font-bold text-gray-900">99% en Visas</p>
        </div>
      </div>

      <!-- Floating card: Viaja Seguro (animate-pulse) -->
      <div class="absolute -right-6 bottom-8 bg-white rounded-2xl shadow-xl border border-gray-100 p-4 flex items-center gap-3 animate-pulse z-10">
        <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
          </svg>
        </div>
        <div>
          <p class="text-lg font-bold text-gray-900">Viaja Seguro</p>
        </div>
      </div>
    </div>
  </div>
</section>
