    flag: '🇦🇪',
    currency: 'AED',
    image: IMG('1512453979798-5ea266f8880c'), // Burj Khalifa skyline
    description: '0% impuestos + estilo de vida premium',
    tag: 'Trabajo',
    tagBg: 'bg-blue-50',
    tagColor: 'text-blue-600',
    slug: '/estudiar-en-dubai',
  },
  {
    name: 'Reino Unido',
    flag: '🇬🇧',
    currency: 'GBP',
    image: IMG('1513635269975-59663e0ac1ad'), // London
    description: 'Universidades top + Graduate Route Visa',
    tag: 'Cultura',
    tagBg: 'bg-purple-50',
    tagColor: 'text-purple-600',
    slug: '/estudiar-en-reino-unido',
  },
  {
    name: 'Irlanda',
    flag: '🇮🇪',
    currency: 'EUR',
    image: IMG('1548092372-2a903fa2ba28'), // Irish cliffs / green
    description: 'Hub tech europeo (Google, Meta, Apple)',
    tag: 'Trabajo',
    tagBg: 'bg-blue-50',
