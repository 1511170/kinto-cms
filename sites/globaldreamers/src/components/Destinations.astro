    slug: '/estudiar-en-irlanda',
  },
  {
    name: 'Nueva Zelanda',
    flag: '🇳🇿',
    currency: 'NZD',
    image: IMG('1507699629798-687146645633'), // NZ mountains
    description: 'Calidad de vida #1 en el mundo',
    tag: 'Aventura',
    tagBg: 'bg-green-50',
    tagColor: 'text-green-600',
    slug: '/estudiar-en-nueva-zelanda',
  },
  {
    name: 'Estados Unidos',
    flag: '🇺🇸',
    currency: 'USD',
    image: IMG('1496442226666-8d4d0b62b1b2'), // NYC skyline
    description: 'Harvard, MIT, Stanford + OPT Visa',
    tag: 'Cultura',
    tagBg: 'bg-purple-50',
    tagColor: 'text-purple-600',
    slug: '/estudiar-en-estados-unidos',
  },
  {
    name: 'Italia',
    flag: '🇮🇹',
    currency: 'EUR',
    image: IMG('1552832230-c0197dd311b5'), // Rome Colosseum
    description: 'Arte, moda, cultura y patrimonio UNESCO',
    tag: 'Cultura',
    tagBg: 'bg-purple-50',
