  {
    name: 'Alemania',
    flag: '🇩🇪',
    currency: 'EUR',
    image: IMG('1560930950-5cc20e80e8f0'), // Berlin
    description: 'Universidades casi gratuitas en Europa',
    tag: 'Tecnología',
    tagBg: 'bg-gray-100',
    tagColor: 'text-gray-600',
    slug: '/estudiar-en-alemania',
  },
  {
    name: 'España',
    flag: '🇪🇸',
    currency: 'EUR',
    image: IMG('1583422409516-2895a77efded'), // Barcelona
