    flag: '🇲🇹',
    currency: 'EUR',
    image: IMG('1605649487212-47bdab064df7'), // Malta blue waters
    description: 'Inglés oficial en el corazón de Europa',
    tag: 'Clima Ideal',
    tagBg: 'bg-yellow-50',
    tagColor: 'text-yellow-600',
    slug: '/estudiar-en-malta',
  },
  {
