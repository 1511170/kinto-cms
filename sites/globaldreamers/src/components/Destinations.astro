---

<section id="destinos" class="bg-gray-50 py-20">
  <div class="max-w-7xl mx-auto px-8 flex flex-col gap-12">
    <!-- Header -->
    <div class="flex flex-col gap-2 text-center">
      <h2 class="font-display font-bold text-4xl text-gray-900">Explora el mundo</h2>
      <p class="text-lg text-gray-500">Elige tu próximo destino</p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {destinations.map(dest => (
        <article class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden flex flex-col hover:shadow-xl transition-all duration-300 group">
          <!-- Image -->
          <div class="relative h-44 overflow-hidden">
            <img
              src={dest.image}
              alt={`${dest.name}, ${dest.description}`}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              loading="lazy"
              decoding="async"
            />
            <!-- Currency overlay -->
            <div class="absolute top-3 left-3 bg-gray-900/80 rounded-lg px-2.5 py-1">
              <span class="text-white text-xs font-bold">{dest.flag} {dest.currency}</span>
            </div>
          </div>

          <!-- Content -->
          <div class="flex flex-col gap-3 p-5 flex-1">
            <h3 class="font-display font-bold text-lg text-gray-900">{dest.name}</h3>
            <p class="text-sm text-gray-500 leading-relaxed flex-1">{dest.description}</p>

            <div class="flex items-center justify-between">
              <!-- Tag -->
              <div class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                </svg>
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-lg ${dest.tagBg} ${dest.tagColor}`}>
                  {dest.tag}
                </span>
              </div>

              <!-- Ver más -->
              <a
                href={dest.slug ?? `#${dest.name.toLowerCase().replace(/\s+/g, '-')}`}
                class="text-sm font-bold text-brand-600 hover:text-brand-700 border border-brand-200 hover:border-brand-400 rounded-lg px-3 py-1.5 transition-colors"
              >
                Ver más
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
