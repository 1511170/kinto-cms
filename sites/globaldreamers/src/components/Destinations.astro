    description: 'Trabaja 48hrs/quincena',
    tag: 'Trabajo',
    tagBg: 'bg-blue-50',
    tagColor: 'text-blue-600',
    slug: '/estudiar-en-australia',
  },
  {
    name: 'Canadá',
    flag: '🇨🇦',
