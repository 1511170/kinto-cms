  'goal-career_vibe-beach': 'espana',
  'goal-career_vibe-nature': 'canada',
  'goal-career_vibe-city': 'alemania',
  'goal-work_vibe-beach': 'australia',
  'goal-work_vibe-nature': 'nueva-zelanda',
  'goal-work_vibe-city': 'dubai'
};

function getRecommendation(goal: string, vibe: string, budget: string): DestinationRecommendation {
  const key = `goal-${goal}_vibe-${vibe}_budget-${budget}`;
  
  if (recommendations[key]) {
    return recommendations[key];
  }
  
  const partialKey = `goal-${goal}_vibe-${vibe}`;
  const fallbackId = fallbacks[partialKey] || 'australia';
  
  const fallbackRec = Object.values(recommendations).find(r => r.id === fallbackId);
  return fallbackRec || recommendations['goal-work_vibe-beach_budget-medium'];
}

const recommendationsJson = JSON.stringify(recommendations);
