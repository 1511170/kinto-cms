  const scriptTag = document.currentScript;
  const recommendations = JSON.parse(scriptTag.dataset.recommendations || '{}');
  
  let selections = { goal: '', vibe: '', budget: '' };

  function showStep(stepNum) {
    document.querySelectorAll('.quiz-step').forEach(el => el.classList.add('hidden'));
    const stepEl = document.getElementById(`step-${stepNum}`);
    if (stepEl) stepEl.classList.remove('hidden');
  }

  function updateProgress(step) {
    const progress = step === 1 ? 33 : step === 2 ? 66 : step === 'result' ? 100 : 33;
    const bar = document.getElementById('progress-bar');
    if (bar) bar.style.width = `${progress}%`;
  }

  function selectOption(category, value, nextStep) {
    selections[category] = value;
    
    if (nextStep === 'result') {
      showResult();
    } else {
      showStep(nextStep);
      updateProgress(parseInt(nextStep));
    }
  }

  function goBack(stepNum) {
    showStep(stepNum);
    updateProgress(stepNum);
  }

  function getGoalLabel(goal) {
    const labels = { language: 'aprender idioma', career: 'carrera profesional', work: 'trabajo' };
    return labels[goal] || goal;
  }

  function getVibeLabel(vibe) {
    const labels = { beach: 'sol y playa', nature: 'naturaleza', city: 'ciudad' };
    return labels[vibe] || vibe;
  }

  function findRecommendation() {
    const key = `goal-${selections.goal}_vibe-${selections.vibe}_budget-${selections.budget}`;
    
    if (recommendations[key]) {
      return recommendations[key];
    }
    
    const fallbacks = {
      'goal-language_vibe-beach': 'malta',
      'goal-language_vibe-nature': 'irlanda',
      'goal-language_vibe-city': 'reino-unido',
      'goal-career_vibe-beach': 'espana',
      'goal-career_vibe-nature': 'canada',
      'goal-career_vibe-city': 'alemania',
      'goal-work_vibe-beach': 'australia',
      'goal-work_vibe-nature': 'nueva-zelanda',
      'goal-work_vibe-city': 'dubai'
    };
    
    const partialKey = `goal-${selections.goal}_vibe-${selections.vibe}`;
    const fallbackId = fallbacks[partialKey] || 'australia';
    
    const allRecs = Object.values(recommendations);
    return allRecs.find(r => r.id === fallbackId) || allRecs[0];
  }

  function showResult() {
    const rec = findRecommendation();
    const flagSvg = flagSVGs[rec.flagCode] || flagSVGs['ca'];
    updateProgress('result');
    
    const resultHTML = `
      <div class="text-center mb-8">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-green-500/10 text-green-600 text-xs font-black uppercase tracking-wider mb-4">
          <span class="material-symbols-outlined text-sm">auto_awesome</span>
          Plan Personalizado Generado
        </div>
        <h3 class="text-2xl md:text-3xl font-black text-slate-900 mb-2">
          <span class="inline-block mr-2">${flagSvg}</span>
          Tu destino ideal es ${rec.name}
        </h3>
        <p class="text-slate-500">Basado en tus metas de ${getGoalLabel(selections.goal)} y ${getVibeLabel(selections.vibe)}.</p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8 mb-8">
        <div class="relative overflow-hidden rounded-2xl aspect-video shadow-lg group">
          <img src="${rec.image}" alt="${rec.name}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-transparent to-transparent flex flex-col justify-end p-6">
            <span class="inline-flex items-center gap-1 text-brand-400 text-xs font-bold uppercase mb-1">
              <span class="material-symbols-outlined text-sm fill-1">verified</span>
              Recomendación Premium
            </span>
            <h4 class="text-xl font-bold text-white">${rec.title}</h4>
          </div>
        </div>
        
        <div class="space-y-3">
          ${rec.benefits.map(b => `
            <div class="flex items-start gap-4 p-4 rounded-xl bg-slate-50 border border-slate-100">
              <span class="material-symbols-outlined text-brand-600 bg-brand-100 p-2 rounded-lg">${b.icon}</span>
              <div>
                <h5 class="font-bold text-sm text-slate-900">${b.title}</h5>
                <p class="text-xs text-slate-500">${b.desc}</p>
              </div>
            </div>
          `).join('')}
        </div>
      </div>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="${rec.href}" class="inline-flex items-center justify-center gap-2 bg-brand-600 text-white text-lg font-bold py-4 px-8 rounded-xl hover:bg-brand-700 transition-all shadow-lg shadow-brand-600/30">
          Ver Detalles de ${rec.name}
          <span class="material-symbols-outlined">arrow_forward</span>
        </a>
        <a href="https://wa.me/61412345678?text=Hola%2C%20me%20interesa%20conocer%20más%20sobre%20${encodeURIComponent(rec.name)}" 
           target="_blank" 
           rel="noopener noreferrer"
           class="inline-flex items-center justify-center gap-2 bg-[#25D366] text-white text-lg font-bold py-4 px-8 rounded-xl hover:bg-[#128C7E] transition-all">
          <span class="material-symbols-outlined">chat</span>
          Hablar por WhatsApp
        </a>
      </div>
      
      <button id="reset-quiz" class="mt-6 text-slate-400 hover:text-slate-600 text-sm font-medium cursor-pointer">
        ← Volver a empezar
      </button>
    `;
    
    const resultContent = document.getElementById('result-content');
    if (resultContent) {
      resultContent.innerHTML = resultHTML;
      const resetBtn = document.getElementById('reset-quiz');
      if (resetBtn) {
        resetBtn.addEventListener('click', resetQuiz);
      }
    }
    showStep('result');
  }

  function resetQuiz() {
    selections = { goal: '', vibe: '', budget: '' };
    showStep(1);
    updateProgress(1);
  }

  // Event Listeners
  (function init() {
    document.querySelectorAll('.quiz-option').forEach(btn => {
      btn.addEventListener('click', function() {
        const category = this.dataset.category;
        const value = this.dataset.value;
        const nextStep = this.dataset.next;
        selectOption(category, value, nextStep);
      });
    });

    const back2 = document.getElementById('back-2');
    const back3 = document.getElementById('back-3');
    
    if (back2) back2.addEventListener('click', () => goBack(1));
    if (back3) back3.addEventListener('click', () => goBack(2));
  })();
</script>
