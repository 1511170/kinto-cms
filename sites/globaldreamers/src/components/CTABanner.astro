---

<section class="relative bg-brand-600 py-20 overflow-hidden">
  <!-- Blur blobs -->
  <div class="absolute top-0 left-1/4 w-72 h-72 bg-purple-400 rounded-full opacity-30 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-64 h-64 bg-blue-400 rounded-full opacity-30 blur-3xl pointer-events-none"></div>

  <div class="relative max-w-3xl mx-auto px-8 text-center flex flex-col items-center gap-8">
    <h2 class="font-display font-bold text-4xl text-white leading-tight">
      ¿Estás listo para cambiar tu vida?
    </h2>

    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 px-8 py-4 bg-white text-brand-600 font-bold rounded-full hover:bg-gray-100 transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1"
      >
        Quiero mi Asesoría
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 px-8 py-4 bg-transparent text-white font-bold rounded-full border-2 border-white/40 hover:border-white transition-all duration-300"
      >
        Agenda GRATIS
      </a>
    </div>
  </div>
</section>
