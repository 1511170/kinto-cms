---
import Layout from '../layouts/Layout.astro';
import { ProductCard } from '@skills-official/shopify-ecommerce';
import { getCachedProducts, getCachedCollections } from '../lib/build-data';

const allProducts = await getCachedProducts();
const allCollections = await getCachedCollections();

const INTERNAL_HANDLES = new Set(['frontpage', 'home-page', 'home', 'all']);
const navCollections = allCollections
  .filter((c: any) => !INTERNAL_HANDLES.has(c.handle.toLowerCase()))
  .slice(0, 6);

const featuredProducts = allProducts.slice(0, 8);
const newProducts = allProducts.slice(8, 12);

// Productos para el promo banner — de la colección "nueva-importacion-pesca" si tiene
const promoCollection = allCollections.find((c: any) => c.handle === 'nueva-importacion-pesca');
const promoProducts = allProducts
  .filter((p: any) => Array.isArray(p.collections) && p.collections.includes('nueva-importacion-pesca'))
  .slice(0, 4);
const promoFallback = promoProducts.length < 4
  ? allProducts.filter((p: any) => Array.isArray(p.collections) && p.collections.includes('pesca')).slice(0, 4)
  : promoProducts;
const promoHandle = promoCollection?.handle ?? 'pesca';
const promoTitle = promoCollection?.title ?? 'Pesca';

const catColors: Record<string, string> = {
  pesca:   'linear-gradient(135deg, #1f3a3e 0%, #0e2126 100%)',
  camping: 'linear-gradient(135deg, #a35a2c 0%, #5a2f15 100%)',
  tiro:    'linear-gradient(135deg, #2a2a2a 0%, #0e0e0e 100%)',
  outdoor: 'linear-gradient(135deg, #1f4a3c 0%, #0e2a20 100%)',
  caza:    'linear-gradient(135deg, #3a2a10 0%, #1f1508 100%)',
};
const catSubtitles: Record<string, string> = {
  pesca:   'Río · Lago · Mar',
  camping: 'Vivir afuera',
  tiro:    'Precisión',
  outdoor: 'Sendero · Montaña',
  caza:    'Campo · Monte',
};

function colBg(handle: string) {
  return catColors[handle.toLowerCase()] ?? 'linear-gradient(135deg, #2b3a32 0%, #1d2e25 100%)';
}
function colSub(handle: string) {
  return catSubtitles[handle.toLowerCase()] ?? '';
}
---

<Layout title="El Norteño — Equipo outdoor desde 1987">
  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-text">
      <div class="eyebrow">Colección · 2026</div>
      <h1 class="h-display">
        Para los<br>
        que viven<br>
        <em>afuera.</em>
      </h1>
      <div class="hero-meta">
        <div class="hero-meta-block">
          <span class="k">Desde 1987</span>
          Equipo elegido a mano por gente que pesca, acampa y camina. Sin atajos.
        </div>
        <div class="hero-meta-block">
          <span class="k">Cobertura</span>
          3 tiendas: Bucaramanga, Medellín y Valledupar. Asesoría real.
        </div>
      </div>
      <div class="hero-cta">
        <a href="/store" class="btn btn-primary">
          Ver tienda
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/store/camping" class="btn btn-outline">Camping</a>
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-img"></div>
      <div class="hero-stat-tag mono">N · 06°33' · O 73°08'</div>
      <div class="hero-label mono" style="top:45%;left:15%">— PÁRAMO DE SANTURBÁN</div>
      <div class="hero-label mono" style="top:30%;right:18%;text-align:right">ALT 3.420 m</div>
      <div class="hero-coords mono">
        EXPEDICIÓN<br>
        BITÁCORA #042<br>
        12.OCT.2026
      </div>
      <div class="hero-stamp">
        <span class="mono">EQUIPO</span>
        <strong class="h-display">N°87</strong>
        <span class="mono">CERTIFICADO</span>
      </div>
    </div>
  </section>

  <!-- ===== STAT BAR ===== -->
  <section class="stat-bar">
    <div class="stat-bar-grid shell">
      {[
        { icon: 'truck',   title: 'Envío nacional',       sub: 'Servientrega y Coordinadora' },
        { icon: 'refresh', title: 'Atención multicanal',  sub: 'WhatsApp · Tienda física · Web' },
        { icon: 'shield',  title: 'Garantía y servicio',  sub: 'Postventa en tienda' },
        { icon: 'leaf',    title: 'Asesoría real',         sub: 'WhatsApp · 3 tiendas físicas' },
      ].map(({ icon, title, sub }) => (
        <div class="stat-item">
          <div class="stat-icon">
            {icon === 'truck' && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            )}
            {icon === 'refresh' && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            )}
            {icon === 'shield' && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            )}
            {icon === 'leaf' && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21c3 0 7-1 9.5-3.5C15.5 15 17 10 17 3c-4 0-8 1.5-10.5 4.5C4 10.5 3 15 3 21z"/><path d="M3 21l8.5-8.5"/></svg>
            )}
          </div>
          <div>
            <div class="stat-title">{title}</div>
            <div class="stat-sub">{sub}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== CATEGORÍAS ===== -->
  {navCollections.length > 0 && (
    <section class="section">
      <div class="shell">
        <div class="section-head">
          <div>
            <div class="h-meta">
              <span class="h-meta-line"></span>
              <span class="mono">01 · Categorías</span>
            </div>
            <h2 class="h-display section-h2">
              Equipo por<br>terreno.
            </h2>
          </div>
          <p class="section-sub">
            Filtra por la actividad que te lleva afuera y arma tu próxima salida.
          </p>
        </div>

        <div class="cat-grid">
          {navCollections.slice(0, 2).map((col: any) => (
            <a href={`/store/${col.handle}`} class="cat-card cat-card-main">
              <div
                class="cat-card-img"
                style={col.image
                  ? `background-image: url(${col.image.url}); background-size: cover; background-position: center`
                  : `background: ${colBg(col.handle)}`}
              ></div>
              <div class="cat-card-overlay"></div>
              <div class="cat-card-content">
                <div>
                  <h3>{col.title}</h3>
                  {colSub(col.handle) && <div class="cat-sub">{colSub(col.handle)}</div>}
                </div>
                <div class="cat-arrow">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          ))}

          <div class="cat-grid-right">
            {navCollections.slice(2, 4).map((col: any) => (
              <a href={`/store/${col.handle}`} class="cat-card cat-card-small">
                <div
                  class="cat-card-img"
                  style={col.image
                    ? `background-image: url(${col.image.url}); background-size: cover; background-position: center`
                    : `background: ${colBg(col.handle)}`}
                ></div>
                <div class="cat-card-overlay"></div>
                <div class="cat-card-content">
                  <div>
                    <h3>{col.title}</h3>
                    {colSub(col.handle) && <div class="cat-sub">{colSub(col.handle)}</div>}
                  </div>
                  <div class="cat-arrow">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </div>
                </div>
              </a>
            ))}
            {navCollections.length > 4 && (
              <div class="cat-grid-right-bottom">
                {navCollections.slice(4, 6).map((col: any) => (
                  <a href={`/store/${col.handle}`} class="cat-card cat-card-small">
                    <div
                      class="cat-card-img"
                      style={col.image
                        ? `background-image: url(${col.image.url}); background-size: cover; background-position: center`
                        : `background: ${colBg(col.handle)}`}
                    ></div>
                    <div class="cat-card-overlay"></div>
                    <div class="cat-card-content" style="padding:18px">
                      <div><h3 style="font-size:22px">{col.title}</h3></div>
                    </div>
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>

        <div class="cat-cta">
          <a href="/store" class="btn btn-ghost">
            Ver toda la tienda
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ===== FEATURED PRODUCTS ===== -->
  {featuredProducts.length > 0 && (
    <section class="section" style="padding-top:48px">
      <div class="shell">
        <div class="section-head">
          <div>
            <div class="h-meta">
              <span class="h-meta-line"></span>
              <span class="mono">02 · Probados en ruta</span>
            </div>
            <h2 class="h-display section-h2">
              Lo más<br>llevado.
            </h2>
          </div>
          <div style="display:flex;gap:12px;align-items:center">
            <a href="/store" class="btn btn-ghost">
              Ver todo
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
        <div class="products-grid">
          {featuredProducts.map((product: any) => (
            <ProductCard product={product} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== PROMO BANNER — colección real con productos reales ===== -->
  {promoFallback.length > 0 && (
    <section class="section" style="padding-top:0;padding-bottom:0;border-bottom:none">
      <div class="shell">
        <div class="banner">
          <div class="banner-text">
            <div class="eyebrow" style="color:var(--terra-2)">Recién importado</div>
            <h2 class="h-display banner-h2">
              Lo último<br>
              <em>en {promoTitle.toLowerCase()}</em>.
            </h2>
            <p class="banner-desc">
              {promoFallback.length} referencias nuevas en stock. Equipo seleccionado
              por nuestro equipo en tienda — listas para enviar a toda Colombia.
            </p>
            <a href={`/store/${promoHandle}`} class="btn btn-terra">
              Ver colección
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="banner-grid">
            {promoFallback.map((p: any) => (
              <a href={`/products/${p.handle}`} class="banner-prod" aria-label={p.title}>
                {p.featuredImage?.url
                  ? <img src={p.featuredImage.url} alt={p.featuredImage.altText ?? p.title} loading="lazy" />
                  : <div class="banner-prod-ph"></div>
                }
                <div class="banner-prod-meta mono">{p.title.slice(0, 38)}{p.title.length > 38 ? '…' : ''}</div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ===== NEW PRODUCTS ===== -->
  {newProducts.length > 0 && (
    <section class="section" style="padding-top:64px">
      <div class="shell">
        <div class="section-head">
          <div>
            <div class="h-meta">
              <span class="h-meta-line"></span>
              <span class="mono">03 · Recién llegado</span>
            </div>
            <h2 class="h-display section-h2">
              Nuevo<br>en tienda.
            </h2>
          </div>
          <a href="/store" class="btn btn-ghost">
            Ver todo
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="products-grid products-grid-4">
          {newProducts.map((product: any) => (
            <ProductCard product={product} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== EMPTY STATE ===== -->
  {allProducts.length === 0 && (
    <section class="section">
      <div class="shell empty-state">
        <div class="eyebrow" style="margin-bottom:16px">Cargando catálogo</div>
        <h2 class="h-display" style="font-size:clamp(48px,6vw,80px);color:var(--pine);margin:0 0 16px">
          Pronto aquí.
        </h2>
        <p style="font-size:16px;color:var(--slate);max-width:400px;margin:0 0 32px">
          Estamos cargando nuestro catálogo de productos. Mientras tanto, contáctanos.
        </p>
        <a href="/contacto" class="btn btn-primary">Contactar por WhatsApp</a>
      </div>
    </section>
  )}

  <!-- ===== NEWSLETTER ===== -->
  <section class="newsletter">
    <div class="shell newsletter-inner">
      <div class="newsletter-left">
        <div class="eyebrow" style="color:var(--sand);opacity:.65">Boletín de campo</div>
        <h2 class="h-display newsletter-h2">
          Lo nuevo<br>primero.
        </h2>
        <p class="newsletter-sub">
          Equipo nuevo, ofertas de temporada y notas de campo. Sin spam.
        </p>
      </div>
      <form data-newsletter-form class="newsletter-form">
        <input
          type="email"
          placeholder="tu@email.com"
          required
          class="newsletter-input"
          aria-label="Tu correo electrónico"
        />
        <button type="submit" class="btn btn-terra newsletter-btn">
          Suscribirse
        </button>
      </form>
    </div>
  </section>
</Layout>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 640px;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    background: var(--bg);
    border-bottom: 1px solid var(--line);
    overflow: hidden;
  }
  .hero-text {
    padding: 80px 60px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 32px;
  }
  .hero-text .h-display {
    font-size: clamp(72px, 9vw, 148px);
    margin: 24px 0 0;
    color: var(--pine);
  }
  .hero-text h1 em {
    font-style: italic;
    font-family: Georgia, "Times New Roman", serif;
    font-weight: 400;
    color: var(--terra);
    text-transform: lowercase;
    letter-spacing: -0.01em;
  }
  .hero-meta {
    display: flex;
    gap: 32px;
    margin-top: 8px;
  }
  .hero-meta-block {
    font-size: 13px;
    max-width: 240px;
    line-height: 1.45;
    color: var(--ink-2);
  }
  .hero-meta-block .k {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--slate);
    display: block;
    margin-bottom: 6px;
  }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }

  /* Hero visual panel */
  .hero-visual {
    position: relative;
    background: var(--pine);
    overflow: hidden;
    min-height: 520px;
  }
  .hero-img {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #2a3a2c 0%, #1d2e25 40%, #14201a 100%);
  }
  .hero-img::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 30% 40%, rgba(184,90,42,.25), transparent 50%),
      radial-gradient(circle at 70% 70%, rgba(192,138,58,.2), transparent 60%),
      repeating-linear-gradient(45deg, transparent 0 22px, rgba(0,0,0,.08) 22px 23px);
  }
  .hero-label {
    position: absolute;
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(243,239,230,.55);
  }
  .hero-stat-tag {
    position: absolute;
    top: 40px;
    left: 40px;
    padding: 8px 14px;
    background: var(--terra);
    color: var(--white);
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    border-radius: var(--radius-md);
  }
  .hero-coords {
    position: absolute;
    bottom: 40px;
    left: 40px;
    color: var(--sand);
    font-size: 11px;
    line-height: 1.6;
    opacity: 0.8;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }
  .hero-stamp {
    position: absolute;
    bottom: 40px;
    right: 40px;
    width: 140px;
    height: 140px;
    border: 1px solid rgba(243,239,230,.35);
    border-radius: 999px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--sand);
    text-align: center;
    font-size: 9px;
    letter-spacing: 0.2em;
    line-height: 1.6;
    text-transform: uppercase;
  }
  .hero-stamp strong {
    font-size: 32px;
    letter-spacing: 0.02em;
    margin: 4px 0;
    color: var(--terra-2);
    display: block;
    line-height: 1;
  }

  /* ===== STAT BAR ===== */
  .stat-bar {
    background: var(--bg-2);
    border-bottom: 1px solid var(--line);
    padding: 24px 0;
  }
  .stat-bar-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .stat-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .stat-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--pine);
    color: var(--sand);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .stat-title { font-weight: 700; font-size: 13px; color: var(--fg); }
  .stat-sub { font-size: 12px; color: var(--slate); margin-top: 2px; }

  /* ===== SECTION SHARED ===== */
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }
  .section-h2 {
    font-size: clamp(48px, 6vw, 88px);
    margin: 16px 0 0;
    color: var(--pine);
  }
  .section-sub {
    max-width: 340px;
    color: var(--slate);
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
  }
  .h-meta {
    display: flex;
    gap: 20px;
    align-items: center;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--slate);
  }
  .h-meta-line {
    width: 40px;
    height: 1px;
    background: var(--line-strong);
    display: block;
  }

  /* ===== CATEGORY GRID ===== */
  .cat-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 16px;
    height: 580px;
  }
  .cat-grid-right {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 16px;
  }
  .cat-grid-right-bottom {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .cat-card {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    cursor: pointer;
    text-decoration: none;
    color: var(--white);
  }
  .cat-card-main { }
  .cat-card-small { }
  .cat-card-img {
    position: absolute;
    inset: 0;
    transition: transform 0.4s ease;
  }
  .cat-card:hover .cat-card-img { transform: scale(1.04); }
  .cat-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(20,32,26,.85) 0%, rgba(20,32,26,.2) 50%, transparent 100%);
  }
  .cat-card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    z-index: 2;
  }
  .cat-card h3 {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 400;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0 0 4px;
    line-height: 0.95;
  }
  .cat-card-small h3 { font-size: 24px; }
  .cat-sub {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .cat-arrow {
    width: 36px;
    height: 36px;
    border-radius: 999px;
    background: rgba(243,239,230,.15);
    border: 1px solid rgba(243,239,230,.3);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.15s;
  }
  .cat-card:hover .cat-arrow {
    background: var(--terra);
    border-color: var(--terra);
  }
  .cat-cta {
    margin-top: 24px;
    display: flex;
    justify-content: center;
  }

  /* ===== PRODUCTS GRID ===== */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .products-grid-4 {
    grid-template-columns: repeat(4, 1fr);
  }

  /* ===== PROMO BANNER ===== */
  .banner {
    background: var(--pine);
    border-radius: var(--radius-lg);
