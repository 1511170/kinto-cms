export function productsForCollection(collectionHandle: string, products: any[]) {
  const direct = products.filter((p: any) =>
    Array.isArray(p.collections) && p.collections.includes(collectionHandle)
  );
  if (direct.length > 0) return direct;

  const subHandles = CATEGORY_HIERARCHY[collectionHandle] ?? [];
  if (subHandles.length > 0) {
    const synthetic = products.filter((p: any) =>
      Array.isArray(p.collections) && p.collections.some((h: string) => subHandles.includes(h))
    );
    if (synthetic.length > 0) return synthetic;
  }

  return direct;
}

export async function getStaticPaths() {
  const collections = await getCachedCollections();
  const allProducts = await getCachedProducts();

  return (collections as any[]).map((c) => {
    const products = productsForCollection(c.handle, allProducts as any[]);
    return {
      params: { handle: c.handle },
      props: { collection: c, products },
    };
  });
}

const { collection, products } = Astro.props;
const allCollections = await getCachedCollections();
const allProductsForCounts = await getCachedProducts();
const INTERNAL = new Set(['frontpage', 'home-page', 'home', 'all']);
const navCollections = (allCollections as any[]).filter(c => !INTERNAL.has(c.handle.toLowerCase()));
const totalProductsCount = (allProductsForCounts as any[]).length;
const collectionCounts: Record<string, number> = {};
for (const col of navCollections) {
  collectionCounts[col.handle] = productsForCollection(col.handle, allProductsForCounts as any[]).length;
}

const notFound = !collection;

function fmtPrice(n: number) {
  return '$' + Math.round(n).toLocaleString('es-CO');
}

// Imágenes locales para categorías principales
const CAT_IMAGES: Record<string, string> = {
  pesca:            '/images/categories/pesca.jpeg',
  camping:          '/images/categories/camping.jpeg',
  'tiro-deportivo': '/images/categories/tiro-deportivo.jpeg',
  tiro:             '/images/categories/tiro-deportivo.jpeg',
  outdoor:          '/images/categories/outdoor.jpeg',
  caza:             '/images/categories/caza.jpeg',
};

// Sub-colecciones definidas estáticamente para cada categoría principal
const subCollections: { handle: string; title: string; count: number }[] = [];
if (collection) {
  const subHandles = CATEGORY_HIERARCHY[collection.handle] ?? [];
  for (const h of subHandles) {
    const meta = navCollections.find((c: any) => c.handle === h);
    if (!meta) continue;
    const count = (allProductsForCounts as any[]).filter(
      (p: any) => Array.isArray(p.collections) && p.collections.includes(h)
    ).length;
    if (count > 0) {
      subCollections.push({
        handle: h,
        title: CATEGORY_LABELS[h] || meta.title,
        count,
      });
    }
  }
}

