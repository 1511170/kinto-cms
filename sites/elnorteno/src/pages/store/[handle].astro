function humanizeHandle(handle: string): string {
  return handle
    .split('-')
    .filter(Boolean)
    .map((part) => part.length <= 3 ? part.toUpperCase() : part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ')
    .replace(/Senuelos/g, 'Señuelos')
    .replace(/Canas/g, 'Cañas');
}

