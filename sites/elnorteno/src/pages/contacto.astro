---
import Layout from '../layouts/Layout.astro';
import { STORE_LOCATIONS, googleMapsUrl } from '../lib/categories';
---

<Layout
  title="Contáctanos"
  description="3 tiendas físicas: Bucaramanga, Medellín y Valledupar. Asesoría por WhatsApp y atención presencial."
>
  <!-- Breadcrumb -->
  <nav class="crumb" aria-label="Breadcrumb">
    <a href="/">Inicio</a>
    <span>/</span>
    <span style="color:var(--ink)">Contáctanos</span>
  </nav>

  <!-- Hero -->
  <div class="contact-hero">
    <div class="coll-hero-eyebrow">Contacto · El Norteño</div>
    <h1>Encuéntra<em>nos</em></h1>
    <p>3 tiendas físicas · Asesoría real por WhatsApp · Desde 1987</p>
  </div>

  <!-- Tiendas -->
  <div class="contact-grid">
    {STORE_LOCATIONS.map((loc) => (
      <article class="contact-card">
        <div class="contact-card-eyebrow">Tienda · {loc.city}</div>
        <h2>{loc.city}</h2>
        <address class="contact-card-address">{loc.address}</address>

        <div class="contact-card-phones">
          {loc.phones.map((p) => (
            <a href={`tel:${p.replace(/[\s()]/g, '')}`}>{p}</a>
          ))}
        </div>

        <div class="contact-card-actions">
          <a
            href={`https://wa.me/${loc.whatsapp}`}
            target="_blank"
            rel="noopener"
            class="contact-btn contact-btn-wa"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.5 14.4c-.3-.1-1.7-.9-2-1s-.5-.1-.7.1c-.2.3-.7.9-.9 1.1s-.4.2-.7.1c-.3-.1-1.3-.5-2.5-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.4.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5s-.7-1.6-.9-2.2c-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.7.4s-.9.9-.9 2.2.9 2.6 1.1 2.8c.1.2 1.8 2.7 4.3 3.8.6.3 1.1.4 1.4.5.6.2 1.1.2 1.6.1.5-.1 1.7-.7 1.9-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.6-.3M12.1 21h-.1c-1.8 0-3.5-.5-5-1.4l-.4-.2-3.7 1 1-3.6-.2-.4c-1-1.6-1.5-3.4-1.5-5.3 0-5.5 4.5-9.9 9.9-9.9 2.7 0 5.2 1 7 2.9 1.9 1.9 2.9 4.4 2.9 7.1 0 5.5-4.5 9.8-9.9 9.8m8.4-18.2C18.2.5 15.2-.6 12.1-.6 5.5-.6.2 4.8.2 11.3c0 2.1.5 4.1 1.6 5.9L0 24l6.9-1.8c1.7.9 3.6 1.4 5.6 1.4 6.5 0 11.9-5.3 11.9-11.9 0-3.2-1.2-6.1-3.4-8.4z"/>
            </svg>
            WhatsApp {loc.whatsappDisplay}
          </a>
          <a
            href={googleMapsUrl(loc.address, loc.city)}
            target="_blank"
            rel="noopener"
            class="contact-btn contact-btn-map"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-7.5 8-13a8 8 0 0 0-16 0c0 5.5 8 13 8 13z"/>
              <circle cx="12" cy="9" r="2.5"/>
            </svg>
            Cómo llegar
          </a>
        </div>
      </article>
    ))}
  </div>

  <!-- Mapa único con 3 marcadores -->
  <section class="contact-map-section">
    <div class="coll-hero-eyebrow" style="text-align:center;margin-bottom:16px;">
      Nuestras 3 tiendas
    </div>
    <h2 class="contact-map-h2">En el mapa</h2>
    <div id="contact-map" class="contact-map"></div>
  </section>

  <link
    slot="head"
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />
  <script
    is:inline
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
  ></script>
  <script is:inline define:vars={{ stores: STORE_LOCATIONS }}>
    function initElNortenoMap() {
      const L = window.L;
      const el = document.getElementById('contact-map');
      if (!L || !el) {
        setTimeout(initElNortenoMap, 100);
        return;
      }
      const map = L.map('contact-map', { scrollWheelZoom: false }).setView([7.5, -74.5], 6);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors',
        maxZoom: 18,
      }).addTo(map);

      const coords = {
        'Bucaramanga': [7.1193, -73.1227],
        'Medellín': [6.2442, -75.5812],
        'Valledupar': [10.4631, -73.2532],
      };

      const markers = [];
      for (const s of stores) {
        const c = coords[s.city];
        if (!c) continue;
        const popup =
          '<div style="font-family:Manrope,system-ui,sans-serif;line-height:1.5;">' +
            '<strong style="font-family:Anton,sans-serif;text-transform:uppercase;font-size:16px;color:#1d2e25;">' + s.city + '</strong><br>' +
            '<span style="color:#2b3a32;">' + s.address + '</span><br>' +
            '<a href="https://wa.me/' + s.whatsapp + '" target="_blank" rel="noopener" style="color:#25d366;font-weight:600;">WhatsApp ' + s.whatsappDisplay + '</a>' +
          '</div>';
        const m = L.marker(c).addTo(map).bindPopup(popup);
        markers.push(m);
      }
      if (markers.length) {
        const group = L.featureGroup(markers);
        map.fitBounds(group.getBounds().pad(0.3));
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initElNortenoMap);
    } else {
      initElNortenoMap();
    }
  </script>
</Layout>
