---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada — El Norteño">
  <div class="notfound">
    <div class="notfound-code">404</div>
    <h1>Página no encontrada</h1>
    <p>La página que buscas no existe o fue movida.</p>
    <div class="notfound-actions">
      <a href="/store" class="btn btn-primary">Ver catálogo</a>
      <a href="/" class="btn btn-outline">Volver al inicio</a>
    </div>
  </div>
</Layout>

<style>
  .notfound {
    text-align: center;
    padding: 120px 24px;
    max-width: 560px;
    margin: 0 auto;
  }
  .notfound-code {
    font-family: var(--font-display);
    font-size: 96px;
    line-height: 1;
    color: var(--pine);
    opacity: 0.25;
    margin-bottom: 16px;
  }
  .notfound h1 {
    font-family: var(--font-display);
    font-size: 32px;
    text-transform: uppercase;
    color: var(--pine);
    margin: 0 0 12px;
  }
  .notfound p {
    color: var(--slate);
    margin: 0 0 32px;
    font-size: 16px;
  }
  .notfound-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
