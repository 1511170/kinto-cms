---
import Layout from '../../layouts/Layout.astro';
import ProductGallery from '../../components/product/ProductGallery.astro';
import { ProductInfo, ProductSchema } from '@skills-official/shopify-ecommerce';
import SchemaOrg from '@skills-community/seo-ai-citations/components/SchemaOrg.astro';
import WhatsappProductCTA from '@skills-community/whatsapp-cta/components/WhatsappProductCTA.astro';
import { getCachedProducts } from '../../lib/build-data';
import { CATEGORY_LABELS } from '../../config/categories';
import { GUIDES } from '../../data/guides';

export async function getStaticPaths() {
  const products = await getCachedProducts();
  return (products as any[]).map((p) => ({
    params: { handle: p.handle },
    props: { product: p },
  }));
}

const { product } = Astro.props;
const notFound = !product;

// Compute related products at render time (cheaper per-page than O(n²) in getStaticPaths)
let related: any[] = [];
if (product) {
  const allProducts = await getCachedProducts();
  const productCollections: string[] = Array.isArray(product.collections) ? product.collections : [];
  const productCollectionSet = new Set(productCollections);
  related = (allProducts as any[])
    .filter((r) =>
      r.handle !== product.handle &&
      Array.isArray(r.collections) &&
      r.collections.some((c: string) => productCollectionSet.has(c))
    )
    .slice(0, 4);
}

function fmtPrice(n: number) {
  return '$' + Math.round(n).toLocaleString('es-CO');
}

const siteUrl = Astro.site?.origin ?? 'https://elnorteno.com';
const productUrl = product ? `${siteUrl}/products/${product.handle}` : `${siteUrl}/store`;

const PRIORITY_COLLECTIONS = [
  'rifles-de-aire-comprimido',
  'armas-de-aire',
  'tiro-deportivo',
  'canas-para-pesca',
  'canas-de-spinning',
  'canas-de-casting',
  'combos-cana-para-pesca',
  'combos-spinning',
  'molinetes-de-pesca',
  'molinetes-de-spinning',
  'molinetes-de-casting',
  'molinetes-de-mosqueo',
  'senuelos-y-carnadas',
  'duras',
  'suaves',
  'anzuelos',
  'jigs',
  'nylon-para-pesca',
  'monofilamento',
  'fluorocarbono',
  'terminales-para-pesca',
  'pesca',
  'colchones-inflables-y-colchonetas',
  'herramientas-alicates-y-otros',
  'camping',
  'outdoor',
  'caza',
];

function getPrimaryCollection(p: any): string | undefined {
  const cols: string[] = Array.isArray(p?.collections) ? p.collections : [];
  return PRIORITY_COLLECTIONS.find((h) => cols.includes(h)) || cols[0];
}

const PRODUCT_GUIDE_LINKS_BY_COLLECTION: Record<string, string[]> = {
  'rifles-de-aire-comprimido': ['miras-para-rifles-de-aire-colombia', 'rifles-aire-55-precio-colombia', 'como-elegir-rifle-aire-comprimido-colombia', 'tiro-deportivo-responsable'],
  'armas-de-aire': ['miras-para-rifles-de-aire-colombia', 'rifles-aire-55-precio-colombia', 'como-elegir-rifle-aire-comprimido-colombia', 'tiro-deportivo-responsable'],
  'tiro-deportivo': ['tiro-deportivo-responsable', 'miras-para-rifles-de-aire-colombia', 'rifles-aire-55-precio-colombia', 'como-elegir-rifle-aire-comprimido-colombia'],
  'canas-para-pesca': ['como-elegir-cana-pesca'],
  'canas-de-spinning': ['como-elegir-cana-pesca'],
  'canas-de-casting': ['como-elegir-cana-pesca'],
  'combos-cana-para-pesca': ['como-elegir-cana-pesca'],
  'combos-spinning': ['como-elegir-cana-pesca'],
  'molinetes-de-pesca': ['como-elegir-cana-pesca'],
  'molinetes-de-spinning': ['como-elegir-cana-pesca'],
  'molinetes-de-casting': ['como-elegir-cana-pesca'],
  'molinetes-de-mosqueo': ['como-elegir-cana-pesca'],
  'senuelos-y-carnadas': ['como-elegir-cana-pesca'],
  duras: ['como-elegir-cana-pesca'],
  suaves: ['como-elegir-cana-pesca'],
  anzuelos: ['como-elegir-cana-pesca'],
  jigs: ['como-elegir-cana-pesca'],
  'nylon-para-pesca': ['como-elegir-cana-pesca'],
  monofilamento: ['como-elegir-cana-pesca'],
  fluorocarbono: ['como-elegir-cana-pesca'],
  'terminales-para-pesca': ['como-elegir-cana-pesca'],
  pesca: ['como-elegir-cana-pesca'],
  camping: ['equipo-basico-camping-colombia'],
  'colchones-inflables-y-colchonetas': ['equipo-basico-camping-colombia'],
  outdoor: ['equipo-basico-camping-colombia'],
  'herramientas-alicates-y-otros': ['equipo-basico-camping-colombia'],
  caza: ['tiro-deportivo-responsable', 'equipo-basico-camping-colombia'],
};

function guidesForProduct(p: any, collectionHandle?: string) {
  const cols: string[] = Array.isArray(p?.collections) ? p.collections : [];
  const guideSlugs = new Set<string>();
  const text = `${p?.title ?? ''} ${p?.handle ?? ''} ${p?.productType ?? ''}`.toLowerCase();
  if (/\bmira\b|\bmiras\b|scope|optic|optica|óptica/.test(text)) {
    guideSlugs.add('miras-para-rifles-de-aire-colombia');
    guideSlugs.add('tiro-deportivo-responsable');
  }
  for (const handle of [collectionHandle, ...cols]) {
    if (!handle) continue;
    for (const slug of PRODUCT_GUIDE_LINKS_BY_COLLECTION[handle] ?? []) guideSlugs.add(slug);
  }
  return [...guideSlugs]
    .map((slug) => GUIDES.find((guide) => guide.slug === slug))
    .filter(Boolean)
    .slice(0, 2);
}

const primaryCollection = product ? getPrimaryCollection(product) : undefined;
const relatedGuides = product ? guidesForProduct(product, primaryCollection) : [];
const primaryCollectionName = primaryCollection
  ? (CATEGORY_LABELS[primaryCollection] || primaryCollection.split('-').join(' '))
  : (product?.productType || 'Tienda');
const primaryCollectionUrl = primaryCollection ? `/store/${primaryCollection}` : '/store';
const breadcrumbItems = product ? [
  { name: 'Inicio', url: '/' },
  { name: 'Tienda', url: '/store' },
  { name: primaryCollectionName, url: primaryCollectionUrl },
  { name: product.title, url: `/products/${product.handle}` },
] : [];

type FAQ = { q: string; a: string };

type ProductGuide = {
  detailHeading: string;
  intro: string;
  bullets: string[];
  faqs: FAQ[];
};

function mapMetafieldFaqs(p: any): FAQ[] {
  const raw = p?.metafields?.faqs;
  if (!Array.isArray(raw)) return [];
  return raw
    .map((faq: any) => ({
      q: faq.q || faq.question || faq.name,
      a: faq.a || faq.answer || faq.text,
    }))
    .filter((faq: FAQ) => faq.q && faq.a);
}

function guideForProduct(p: any, collectionHandle?: string): ProductGuide {
  const title = p?.title || 'este producto';
  const category = collectionHandle || p?.productType || '';
  const normalizedTitle = String(title).toLowerCase();
  const caliberMatch = normalizedTitle.match(/(?:cal(?:ibre)?\.?\s*)?(4[,.]5|5[,.]5|6[,.]35|7[,.]62)\b/);
  const caliberText = caliberMatch ? caliberMatch[1].replace('.', ',') : undefined;

  if (['rifles-de-aire-comprimido', 'armas-de-aire', 'tiro-deportivo'].includes(category)) {
    const caliberFaq = caliberText
      ? { q: `¿Qué significa calibre ${caliberText} en ${title}?`, a: `El calibre ${caliberText} indica el diámetro aproximado del diábolo compatible. Antes de comprar, confirma disponibilidad de munición/diábolos, uso deportivo previsto, accesorios y condiciones de envío con un asesor de El Norteño.` }
      : { q: '¿Cómo confirmo el calibre compatible?', a: 'Revisa la ficha del producto, el empaque o consulta por WhatsApp. Confirmar calibre evita comprar diábolos o accesorios incompatibles.' };
    return {
      detailHeading: 'Uso deportivo responsable',
      intro: `${title} hace parte de nuestro catálogo de tiro deportivo y armas de aire. Antes de comprar, valida disponibilidad, calibre, accesorios compatibles y condiciones de uso responsable con un asesor de El Norteño.`,
      bullets: ['Confirma calibre, potencia y accesorios incluidos.', 'Revisa compatibilidad con diábolos, miras, estuche y mantenimiento.', 'Compra y despacho sujetos a disponibilidad, validaciones internas y normativa aplicable en Colombia.'],
      faqs: [
        caliberFaq,
        { q: `¿${title} está disponible para envío?`, a: 'La disponibilidad y el despacho dependen del inventario vigente, ciudad de destino, validaciones internas y condiciones aplicables para esta categoría. Confírmalo por WhatsApp antes de comprar.' },
        { q: '¿Puedo recibir asesoría antes de comprar?', a: 'Sí. El Norteño ofrece asesoría por WhatsApp y en tiendas físicas para revisar calibre, accesorios, uso previsto y compatibilidad.' },
        { q: '¿Qué debo revisar antes de elegir un producto de tiro deportivo?', a: 'Revisa calibre, marca, garantía, accesorios compatibles, mantenimiento, disponibilidad de consumibles y cumplimiento de la normativa aplicable.' },
      ],
    };
  }

  if (['pesca', 'canas-para-pesca', 'canas-de-spinning', 'canas-de-casting', 'combos-cana-para-pesca', 'combos-spinning', 'senuelos-y-carnadas', 'duras', 'suaves', 'molinetes-de-pesca', 'molinetes-de-spinning', 'molinetes-de-casting', 'molinetes-de-mosqueo', 'anzuelos', 'jigs', 'nylon-para-pesca', 'monofilamento', 'fluorocarbono', 'terminales-para-pesca'].includes(category)) {
    return {
      detailHeading: 'Compatibilidad de pesca',
      intro: `${title} está pensado para armar o complementar un equipo de pesca deportiva. La mejor elección depende de técnica, especie objetivo, ambiente de pesca y compatibilidad con caña, molinete, línea o señuelo.`,
      bullets: ['Valida tamaño, resistencia, peso y uso recomendado.', 'Combina la referencia con línea, caña, molinete o terminales compatibles.', 'Consulta por WhatsApp si buscas una recomendación para río, lago, mar o una especie específica.'],
      faqs: [
        { q: `¿Cómo sé si ${title} sirve para mi tipo de pesca?`, a: 'Revisa técnica, ambiente, especie objetivo, resistencia y compatibilidad con el resto del equipo. Si tienes dudas, un asesor puede ayudarte por WhatsApp.' },
        { q: '¿El Norteño ayuda a combinar caña, molinete, línea y señuelo?', a: 'Sí. Puedes indicar tu equipo actual o el tipo de pesca que haces para validar opciones compatibles disponibles.' },
        { q: '¿Hacen envíos de productos de pesca en Colombia?', a: 'Sí. El Norteño ofrece envío nacional sujeto a disponibilidad, ciudad de destino y condiciones logísticas del producto.' },
      ],
    };
  }

  if (['camping', 'outdoor', 'caza'].includes(category)) {
    return {
      detailHeading: 'Equipo para salida de campo',
      intro: `${title} hace parte del equipo outdoor seleccionado por El Norteño para camping, campo, viaje o actividades al aire libre. Evalúa tamaño, peso, resistencia, mantenimiento y condiciones del destino antes de comprar.`,
      bullets: ['Revisa medidas, peso, material y facilidad de transporte.', 'Confirma si aplica para lluvia, frío, uso frecuente o salidas ocasionales.', 'Consulta disponibilidad, garantía y recomendaciones según ciudad o destino.'],
      faqs: [
        { q: `¿${title} sirve para camping o salidas outdoor?`, a: 'Depende del destino, clima, frecuencia de uso y necesidades del usuario. Revisa la ficha y consulta por WhatsApp si necesitas una recomendación específica.' },
        { q: '¿Puedo recoger en tienda física?', a: 'Según disponibilidad, puedes coordinar recogida o asesoría en tiendas de Bucaramanga, Medellín y Valledupar.' },
        { q: '¿Tiene garantía?', a: 'La garantía depende de la marca y referencia. Puedes confirmar condiciones en la página del producto o por WhatsApp.' },
      ],
    };
  }

  return {
    detailHeading: 'Detalles del producto',
    intro: `${title} está disponible en El Norteño con asesoría por WhatsApp, envío nacional y atención en tiendas físicas. Revisa marca, categoría, disponibilidad y compatibilidad antes de finalizar la compra.`,
    bullets: ['Confirma disponibilidad antes de comprar.', 'Revisa marca, SKU, precio y condiciones de garantía.', 'Consulta por WhatsApp si necesitas una recomendación o producto complementario.'],
    faqs: [
      { q: `¿${title} está disponible?`, a: 'La disponibilidad depende del inventario vigente. Puedes confirmarla desde el botón de WhatsApp del producto.' },
      { q: '¿Hacen envíos en Colombia?', a: 'Sí. El Norteño ofrece envío nacional sujeto a cobertura logística, disponibilidad y características del producto.' },
      { q: '¿Puedo pedir asesoría antes de comprar?', a: 'Sí. Puedes contactar a El Norteño por WhatsApp o visitar una tienda física para recibir orientación.' },
    ],
  };
}

const productGuide = product ? guideForProduct(product, primaryCollection) : undefined;
const metafieldFaqs = product ? mapMetafieldFaqs(product) : [];
const productFaqs = metafieldFaqs.length > 0 ? metafieldFaqs : (productGuide?.faqs ?? []);
---

{notFound && (
  <Layout title="Producto no encontrado" whatsappContext={{ type: 'general' }}>
    <div style="text-align:center;padding:120px 24px;">
      <h1 style="font-family:var(--font-display);font-size:48px;color:var(--pine);text-transform:uppercase;margin:0 0 16px;">Producto no encontrado</h1>
      <p style="color:var(--slate);margin:0 0 24px;">El producto que buscas no existe o fue removido.</p>
      <a href="/store" class="btn btn-primary">Ver catálogo</a>
    </div>
  </Layout>
)}

{!notFound && product && (
  <Layout
    title={product.seo?.title || product.title}
    description={product.seo?.description || product.description}
    image={product.featuredImage?.url}
    whatsappContext={{
      type: 'product',
      name: product.title,
      url: `${Astro.site?.origin ?? 'https://elnorteno.com'}/products/${product.handle}`,
    }}
  >
    <ProductSchema
      product={product}
      url={productUrl}
      siteUrl={siteUrl}
      sellerName="El Norteño"
      sellerUrl={siteUrl}
      categoryName={primaryCollectionName}
      slot="head"
    />
    <SchemaOrg
      type={productFaqs.length > 0 ? ['BreadcrumbList', 'FAQPage'] : ['BreadcrumbList']}
      siteUrl={siteUrl}
      siteName="El Norteño"
      siteLanguage="es"
      breadcrumbs={breadcrumbItems}
      faqs={productFaqs}
      slot="head"
    />

    <!-- Breadcrumb -->
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Inicio</a>
      <span>/</span>
      <a href="/store">Tienda</a>
      <span>/</span>
      <a href={primaryCollectionUrl}>{primaryCollectionName}</a>
      <span>/</span>
      <span style="color:var(--ink)">{product.title}</span>
    </nav>

    <!-- PDP grid: gallery + info -->
    <section class="pdp">
      <ProductGallery images={product.images ?? []} />
      <div class="pdp-right">
        <ProductInfo product={product}>
          <WhatsappProductCTA
            slot="cta-extras"
            phone="573156819303"
            productName={product.title}
            productUrl={`${Astro.site?.origin ?? 'https://elnorteno.pages.dev'}/products/${product.handle}`}
            productId={product.variants?.[0]?.sku ?? product.handle}
            productBrand={product.vendor}
            productCategory={product.productType ?? product.tags?.[0]}
            messageTemplate='Hola, vi este producto en El Norteño y me interesa: "{name}". ¿Está disponible? {url}'
            label="Consultar por WhatsApp"
          />
        </ProductInfo>

        <!-- Trust badges -->
        <div class="pdp-features">
          <div class="pdp-feature">
            <div class="ico">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h11v9H3z"/><path d="M14 10h4l3 3v3h-7z"/><circle cx="7" cy="18" r="1.5"/><circle cx="17" cy="18" r="1.5"/></svg>
            </div>
            <div><strong>Envío nacional</strong><span>Servientrega y Coordinadora</span></div>
          </div>
          <div class="pdp-feature">
            <div class="ico">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 4 6v6c0 4 3 7 8 9 5-2 8-5 8-9V6l-8-3Z"/></svg>
            </div>
            <div><strong>Garantía 2 años</strong><span>En este producto</span></div>
          </div>
          <div class="pdp-feature">
            <div class="ico">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 15-6l3 3"/><path d="M21 4v5h-5"/><path d="M21 12a9 9 0 0 1-15 6l-3-3"/><path d="M3 20v-5h5"/></svg>
            </div>
            <div><strong>30 días</strong><span>Para devolución</span></div>
          </div>
          <div class="pdp-feature">
            <div class="ico">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21C12 21 4 13.5 4 9a8 8 0 0 1 16 0c0 4.5-8 12-8 12z"/><circle cx="12" cy="9" r="2"/></svg>
            </div>
            <div><strong>Recoge en tienda</strong><span>Bucaramanga · Medellín · Valledupar</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Tabs -->
    <section class="pdp-tabs">
      <nav class="pdp-tabs-nav" role="tablist">
        <button class="pdp-tab on" data-tab="detalles" role="tab" aria-selected="true">Detalles</button>
        <button class="pdp-tab" data-tab="specs" role="tab" aria-selected="false">Ficha técnica</button>
        <button class="pdp-tab" data-tab="reviews" role="tab" aria-selected="false">Reseñas · 124</button>
        <button class="pdp-tab" data-tab="envio" role="tab" aria-selected="false">Envío y devoluciones</button>
      </nav>

      <!-- Detalles -->
      <div class="pdp-tab-content" data-panel="detalles">
        <div class="pdp-tab-body">
          <div>
            <div class="pdp-tab-eyebrow">{productGuide?.detailHeading ?? 'Detalles'}</div>
            <p>{productGuide?.intro}</p>
            {product.description && <p>{product.description}</p>}
          </div>
          <div>
            <div class="pdp-tab-eyebrow">Antes de comprar</div>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
              {(productGuide?.bullets ?? []).map((item, i) => (
                <li style="display:flex;gap:10px;align-items:flex-start;font-size:14px;">
                  <span style="color:var(--terra);font-family:var(--font-mono);font-size:11px;margin-top:3px;flex-shrink:0;">0{i+1}</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- Specs -->
      <div class="pdp-tab-content" data-panel="specs" hidden>
        <div class="pdp-tab-body">
          <dl class="spec-table">
            <dt>Marca</dt><dd>{product.vendor || '—'}</dd>
            <dt>Categoría</dt><dd>{product.productType || '—'}</dd>
            <dt>SKU</dt><dd>{product.variants?.[0]?.sku || product.handle.toUpperCase()}</dd>
            <dt>Material principal</dt><dd>Según especificación técnica</dd>
            <dt>Origen</dt><dd>Diseño Colombia</dd>
          </dl>
          <dl class="spec-table">
            <dt>Garantía</dt><dd>2 años (defectos de fábrica)</dd>
            <dt>Vida útil estimada</dt><dd>5-8 años uso intenso</dd>
            <dt>Cuidado</dt><dd>Ver etiqueta del producto</dd>
            <dt>Resistencia</dt><dd>Apta para uso en campo</dd>
          </dl>
        </div>
      </div>

      <!-- Reseñas -->
      <div class="pdp-tab-content" data-panel="reviews" hidden>
        <div style="display:grid;grid-template-columns:1fr 2fr;gap:48px;max-width:1100px;">
          <div>
            <div style="font-family:var(--font-display);font-size:72px;line-height:1;color:var(--pine);">4.8</div>
            <div style="color:var(--gold);font-size:20px;margin:8px 0;">★★★★★</div>
            <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--slate);">Basado en 124 reseñas</div>
            <div style="margin-top:24px;">
              {[[5,72],[4,20],[3,5],[2,2],[1,1]].map(([n, pct]) => (
                <div class="review-bar-row">
                  <span style="width:14px;color:var(--slate);font-size:12px;">{n}</span>
                  <div class="review-bar-track"><div class="review-bar-fill" style={`width:${pct}%`}></div></div>
                  <span style="width:32px;text-align:right;font-family:var(--font-mono);font-size:11px;color:var(--slate);">{pct}%</span>
                </div>
              ))}
            </div>
          </div>
          <div>
            {[
              { name: 'Mateo R.', loc: 'Bucaramanga · Verificado', date: '15 abr 2026', rating: 5, title: 'Muy buena calidad', text: 'Llevo 3 meses usándolo en salidas de fin de semana. Aguanta lluvia, polvo, todo. La construcción se siente sólida.' },
              { name: 'Laura C.', loc: 'Medellín · Verificado', date: '22 mar 2026', rating: 5, title: 'Cumple lo prometido', text: 'Lo compré para el viaje al Cocuy. Funcionó perfecto a 4.000m. La asesoría por WhatsApp también fue muy buena.' },
              { name: 'Andrés P.', loc: 'Valledupar · Verificado', date: '8 feb 2026', rating: 4, title: 'Casi perfecto', text: 'Solo le bajo una estrella porque el empaque venía un poco arrugado, pero el producto en sí está impecable.' },
            ].map((r) => (
              <div class="review-card">
                <div class="review-meta">
                  <div>
                    <div style="font-weight:600;font-size:14px;">{r.name}</div>
                    <div style="font-family:var(--font-mono);font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:var(--slate);">{r.loc}</div>
                  </div>
                  <div style="font-family:var(--font-mono);font-size:11px;color:var(--slate);">{r.date}</div>
                </div>
                <div class="review-stars">{'★'.repeat(r.rating)}{'☆'.repeat(5-r.rating)}</div>
                <div class="review-title">{r.title}</div>
                <div class="review-text">{r.text}</div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Envío -->
      <div class="pdp-tab-content" data-panel="envio" hidden>
        <div class="pdp-tab-body">
          <div>
            <div class="pdp-tab-eyebrow">Envíos</div>
            <p>Envío nacional por <strong>Servientrega</strong> y <strong>Coordinadora</strong> con guía rastreable. Tarifa según ciudad y peso. Entrega entre 1-5 días hábiles.</p>
            <p>También puedes recoger sin costo en cualquiera de nuestras tres tiendas físicas: <strong>Bucaramanga, Medellín y Valledupar</strong>.</p>
          </div>
          <div>
            <div class="pdp-tab-eyebrow">Devoluciones</div>
            <p>Tienes <strong>30 días</strong> desde la entrega para devolver tu producto, sin preguntas, siempre que esté en su empaque original y sin uso.</p>
            <p>Si encuentras un defecto de fábrica, lo reparamos o reemplazamos durante los <strong>2 años de garantía</strong>. Escríbenos por WhatsApp y nos encargamos.</p>
          </div>
        </div>
      </div>
    </section>

    {productFaqs.length > 0 && (
      <section class="pdp-faq" aria-labelledby="pdp-faq-title">
        <div class="section-head">
          <div>
            <div class="h-meta"><span class="line-el"></span><span>Preguntas frecuentes</span></div>
            <h2 id="pdp-faq-title">Antes de decidir.</h2>
          </div>
        </div>
        <div class="pdp-faq-list">
          {productFaqs.map((faq) => (
            <details class="pdp-faq-item">
              <summary>{faq.q}</summary>
              <p>{faq.a}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    {relatedGuides.length > 0 && (
      <section class="pdp-guides" aria-labelledby="pdp-guides-title">
        <div class="section-head">
          <div>
            <div class="h-meta"><span class="line-el"></span><span>Guías relacionadas</span></div>
            <h2 id="pdp-guides-title">Compra con más contexto.</h2>
          </div>
        </div>
        <div class="pdp-guide-grid">
          {relatedGuides.map((guide) => guide && (
            <a href={`/guias/${guide.slug}/`} class="pdp-guide-card">
              <span>{guide.category}</span>
              <strong>{guide.title}</strong>
              <small>{guide.description}</small>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Relacionados -->
    {related.length > 0 && (
      <section class="rel-section">
        <div class="section-head">
          <div>
            <div class="h-meta"><span class="line-el"></span><span>Lo combinan con</span></div>
            <h2>También<br />llevaron.</h2>
          </div>
        </div>
        <div class="rel-grid">
          {related.map((p: any) => (
            <a href={`/products/${p.handle}`} class="rel-card">
              <div class="rel-img">
                {p.featuredImage?.url
                  ? <img src={p.featuredImage.url} alt={p.featuredImage.altText ?? p.title} loading="lazy" />
                  : <div style="width:100%;height:100%;background:var(--bg-2);"></div>
                }
              </div>
              <div class="rel-brand">{p.vendor || ''}</div>
              <div class="rel-name">{p.title}</div>
              <div class="rel-price">{p.price ? fmtPrice(p.price) : ''}</div>
            </a>
          ))}
        </div>
      </section>
    )}
  </Layout>
)}

<style>
  .pdp-right { padding-top: 12px; }
  .pdp-faq {
    max-width: 1180px;
    margin: clamp(52px, 7vw, 96px) auto 0;
    padding: 0 clamp(20px, 4vw, 48px);
  }
  .pdp-guides {
    max-width: 1180px;
    margin: clamp(40px, 6vw, 80px) auto 0;
    padding: 0 clamp(20px, 4vw, 48px);
  }
  .pdp-guide-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }
  .pdp-guide-card {
    display: grid;
    gap: 8px;
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: color-mix(in srgb, var(--sand) 35%, var(--paper));
    color: inherit;
    text-decoration: none;
    transition: transform .2s ease, border-color .2s ease;
  }
  .pdp-guide-card:hover {
    transform: translateY(-2px);
    border-color: var(--terra);
  }
  .pdp-guide-card span {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--terra);
  }
  .pdp-guide-card strong {
    color: var(--pine);
    font-size: 18px;
    line-height: 1.25;
  }
  .pdp-guide-card small {
    color: var(--slate);
    font-size: 14px;
    line-height: 1.55;
  }
  .pdp-faq-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }
  .pdp-faq-item {
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--paper);
    overflow: hidden;
  }
  .pdp-faq-item summary {
    cursor: pointer;
    list-style: none;
    padding: 18px 20px;
    color: var(--pine);
    font-weight: 700;
    line-height: 1.35;
  }
  .pdp-faq-item summary::-webkit-details-marker { display: none; }
  .pdp-faq-item summary::after {
    content: '+';
    float: right;
    color: var(--terra);
    font-family: var(--font-mono);
    margin-left: 12px;
  }
  .pdp-faq-item[open] summary::after { content: '–'; }
  .pdp-faq-item p {
    margin: 0;
    padding: 0 20px 20px;
    color: var(--slate);
    font-size: 14px;
    line-height: 1.65;
  }
  @media (max-width: 900px) {
    .pdp-faq-list,
    .pdp-guide-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Tab switcher
  const tabs = document.querySelectorAll<HTMLButtonElement>('.pdp-tab');
  const panels = document.querySelectorAll<HTMLElement>('.pdp-tab-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach(t => { t.classList.toggle('on', t === tab); t.setAttribute('aria-selected', String(t === tab)); });
      panels.forEach(p => { p.hidden = p.dataset.panel !== target; });
    });
  });
</script>
