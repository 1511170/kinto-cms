---
import Layout from '../../layouts/Layout.astro';
import SchemaOrg from '@skills-community/seo-ai-citations/components/SchemaOrg.astro';
import { GUIDES } from '../../data/guides';

const siteUrl = Astro.site?.origin ?? 'https://elnorteno.com';
const guides = GUIDES.map((guide) => ({
  title: guide.title,
  description: guide.description,
  href: `/guias/${guide.slug}/`,
  category: guide.category,
}));

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Guías', url: '/guias' },
];
---

<Layout
  title="Guías de compra outdoor, pesca, camping y tiro deportivo"
  description="Guías informativas de El Norteño para elegir equipo de pesca, camping, outdoor y tiro deportivo responsable en Colombia."
  canonical={`${siteUrl}/guias/`}
  whatsappContext={{ type: 'general' }}
>
  <SchemaOrg
    type="BreadcrumbList"
    siteUrl={siteUrl}
    siteName="El Norteño"
    siteLanguage="es"
    breadcrumbs={breadcrumbs}
    slot="head"
  />

  <nav class="crumb" aria-label="Breadcrumb">
    <a href="/">Inicio</a><span>/</span><span style="color:var(--ink)">Guías</span>
  </nav>

  <main class="guides-page">
    <header class="guides-hero">
      <div class="coll-hero-eyebrow">Guías · El Norteño</div>
      <h1>Guías para comprar mejor.</h1>
      <p>Contenido informativo y verificable para elegir equipo outdoor, pesca, camping y tiro deportivo responsable en Colombia.</p>
    </header>

    <section class="guides-grid" aria-label="Guías disponibles">
      {guides.map((guide) => (
        <a class="guide-card" href={guide.href}>
          <div class="guide-card-eyebrow">{guide.category}</div>
          <h2>{guide.title}</h2>
          <p>{guide.description}</p>
          <span>Leer guía →</span>
        </a>
      ))}
    </section>
  </main>
</Layout>

<style>
  .guides-page { max-width: 1240px; margin: 0 auto; padding: 0 clamp(20px, 4vw, 48px) 96px; }
  .guides-hero { padding: clamp(52px, 8vw, 110px) 0 clamp(34px, 5vw, 68px); }
  .guides-hero h1 { max-width: 860px; margin: 12px 0 18px; font-family: var(--font-display); font-size: clamp(48px, 8vw, 100px); line-height: .9; color: var(--pine); text-transform: uppercase; letter-spacing: -.03em; }
  .guides-hero p { max-width: 700px; color: var(--slate); font-size: 18px; line-height: 1.7; }
  .guides-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; }
  .guide-card { display: block; min-height: 260px; padding: 28px; border: 1px solid var(--line); border-radius: 22px; background: var(--paper); color: inherit; text-decoration: none; transition: transform .18s ease, border-color .18s ease; }
  .guide-card:hover { transform: translateY(-3px); border-color: var(--terra); }
  .guide-card-eyebrow { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--terra); }
  .guide-card h2 { margin: 16px 0 12px; font-family: var(--font-display); font-size: clamp(28px, 4vw, 48px); line-height: .96; text-transform: uppercase; color: var(--pine); }
  .guide-card p { color: var(--slate); line-height: 1.6; }
  .guide-card span { display: inline-block; margin-top: 16px; font-weight: 800; color: var(--pine); }
  @media (max-width: 800px) { .guides-grid { grid-template-columns: 1fr; } }
</style>
