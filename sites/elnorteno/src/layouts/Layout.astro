---
import siteConfig from '../../config/site.config.ts';
import StoreHeader from '../components/layout/StoreHeader.astro';
import StoreFooter from '../components/layout/StoreFooter.astro';
import {
  CartDrawer,
  OrganizationSchema,
  GTMSetup,
  LittledataPixel,
} from '@skills-official/shopify-ecommerce';
import GoogleAnalytics from '@skills-official/tracking-analytics/components/GoogleAnalytics.astro';
import WhatsappFloatingButton from '@skills-community/whatsapp-cta/components/WhatsappFloatingButton.astro';
import { getCachedCollections } from '../lib/build-data';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  noindex?: boolean;
  whatsappContext?: {
    type: 'product' | 'collection' | 'general';
    name?: string;
    url?: string;
  };
}

const {
  title = siteConfig.site.name,
  description = siteConfig.site.description,
  canonical = Astro.url.href,
  image = '/og-image.png',
  type = 'website',
  publishedTime,
  modifiedTime,
  author = siteConfig.site.name,
  noindex = false,
  whatsappContext = { type: 'general' },
} = Astro.props;

const siteName = siteConfig.site.name;
const siteUrl = `https://${siteConfig.site.domain}`;

// Generar mensaje de WhatsApp contextual
function buildWhatsappMessage(ctx: typeof whatsappContext): string {
  const url = ctx.url ?? `${siteUrl}${Astro.url.pathname}`;
  switch (ctx.type) {
    case 'product':
      return `Hola, me interesa "${ctx.name}". ¿Está disponible? ${url}`;
    case 'collection':
      return `Hola, quiero ver más de ${ctx.name}. ${url}`;
    default:
      return 'Hola, vengo de El Norteño y quiero información.';
  }
}
const whatsappMessage = buildWhatsappMessage(whatsappContext);
const whatsappUrl = `https://wa.me/573156819303?text=${encodeURIComponent(whatsappMessage)}`;
const fullImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
const titleFull = title === siteName ? title : `${title} | ${siteName}`;

const collections = await getCachedCollections();

const littledataId = import.meta.env.LITTLEDATA_TRACKER_ID;
const gtmId = import.meta.env.GTM_CONTAINER_ID;
const gaId = import.meta.env.GA_MEASUREMENT_ID;
---

<!DOCTYPE html>
<html lang={siteConfig.site.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO básico -->
    <title>{titleFull}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={titleFull} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={fullImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={siteConfig.site.language.replace('-', '_')} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {author && <meta property="article:author" content={author} />}

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titleFull} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImage} />

    <!-- AI Citations -->
    <link rel="alternate" type="text/plain" href="/llms.txt" />

    <!-- Favicon -->
    {siteConfig.site.favicon && (
      <link rel="icon" type="image/x-icon" href={siteConfig.site.favicon} />
    )}

    <!-- Tracking -->
    {gaId && <GoogleAnalytics measurementId={gaId} />}
    {gtmId && <GTMSetup containerId={gtmId} />}
    {littledataId && <LittledataPixel trackerId={littledataId} />}

    <!-- Schema.org -->
    <OrganizationSchema config={siteConfig} />

    <!-- Shopify ecommerce design tokens -->
    <link rel="stylesheet" href="/shopify-tokens.css" />

    <!-- Skills inyectan meta tags, schemas, scripts -->
    <slot name="head" />
  </head>
  <body class="antialiased">
    <StoreHeader collections={collections} brandName={siteName} />

    <main>
      <slot />
    </main>

    <StoreFooter collections={collections} brandName={siteName} />
    <CartDrawer whatsappUrl={whatsappUrl} />
    <WhatsappFloatingButton
      phone="573156819303"
      message={whatsappMessage}
      label="Escribir por WhatsApp"
    />
  </body>
</html>
