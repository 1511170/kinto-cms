---
import { SearchOverlay } from '@skills-official/shopify-ecommerce';
import type { Collection } from '@skills-official/shopify-ecommerce';
import { buildNavCategories } from '../../lib/categories';

interface Props {
  collections: Collection[];
  brandName?: string;
}

const { collections, brandName = 'El Norteño' } = Astro.props;
const availableHandles = new Set(collections.map((c) => c.handle.toLowerCase()));
const mainCategories = buildNavCategories(availableHandles);

const announcements = [
  'Equipo outdoor profesional · Desde 1987',
  '3 tiendas: Bucaramanga · Medellín · Valledupar',
  'Asesoría especializada por WhatsApp',
  'Envío nacional · Servientrega y Coordinadora',
  'Garantía y servicio postventa en tienda',
];
---

<!-- Announcement bar -->
<div class="announce">
  <div class="announce-track" aria-hidden="true">
    <div class="announce-reel">
      {[...announcements, ...announcements].map((msg) => (
        <span>{msg}</span>
      ))}
    </div>
  </div>
  <div class="announce-right mono">
    <a href="/">Inicio</a>
    <span>·</span>
    <a href="/contacto">Contáctanos</a>
  </div>
</div>

<!-- Main header -->
<header data-store-header class="hdr">
  <div class="hdr-row">
    <!-- Left: nav -->
    <nav class="hdr-nav" aria-label="Navegación principal">
      <a href="/" class="hdr-link">Inicio</a>

      <!-- Tienda con megamenu -->
      <div class="hdr-megamenu-wrap" data-megamenu>
        <button
          type="button"
          class="hdr-link megamenu-trigger"
          data-megamenu-trigger
          aria-haspopup="true"
          aria-expanded="false"
        >
          Tienda
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m1 1 4 4 4-4"/>
          </svg>
        </button>

        <div class="megamenu" data-megamenu-panel>
          {mainCategories.map((cat) => (
            <div class="megamenu-col">
              <a
                class="megamenu-col-head"
                href={cat.parentHandle ? `/store/${cat.parentHandle}` : '/store'}
              >
                {cat.title}
              </a>
              {cat.subs.length > 0 && (
                <div class="megamenu-sub">
                  {cat.subs.slice(0, 12).map((sub) => (
                    <a href={`/store/${sub.handle}`}>{sub.title}</a>
                  ))}
                </div>
              )}
              {cat.parentHandle && cat.subs.length > 0 && (
                <a class="megamenu-foot" href={`/store/${cat.parentHandle}`}>
                  Ver toda →
                </a>
              )}
            </div>
          ))}
        </div>
      </div>

      <a href="/contacto" class="hdr-link">Contáctanos</a>
    </nav>

    <!-- Center: brand mark -->
    <a href="/" class="brand" aria-label={brandName}>
      <span class="brand-mark">EL NORTEÑO</span>
      <span class="brand-sub mono">EST · 1987 · COLOMBIA</span>
    </a>

    <!-- Right: search + actions -->
    <div class="hdr-actions">
      <button data-search-toggle class="search-pill" aria-label="Buscar productos">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
        </svg>
        <span>Buscar</span>
        <kbd>⌘K</kbd>
      </button>
      <a href="/cuenta" class="icon-btn" aria-label="Mi cuenta">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
        </svg>
      </a>
      <button data-cart-toggle class="icon-btn" aria-label="Carrito">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 6h15l-1.5 9H7.5L6 6z"/><path d="M6 6 5 3H2"/>
          <circle cx="9" cy="20" r="1.5"/><circle cx="18" cy="20" r="1.5"/>
        </svg>
        <span data-cart-count class="cart-badge" hidden>0</span>
      </button>
      <button class="icon-btn hdr-hamburger" data-menu-toggle aria-label="Menú" aria-expanded="false">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav drawer -->
  <div class="mobile-nav" data-mobile-nav aria-hidden="true">
    <div class="mobile-nav-inner">
      <a href="/" class="mobile-nav-link">Inicio</a>

      {mainCategories.map((cat) => (
        <details class="mobile-nav-cat">
          <summary>{cat.title}</summary>
          <div class="sub-list">
            {cat.parentHandle && (
              <a href={`/store/${cat.parentHandle}`}>Toda la sección →</a>
            )}
            {cat.subs.map((sub) => (
              <a href={`/store/${sub.handle}`}>{sub.title}</a>
            ))}
          </div>
        </details>
      ))}

      <a href="/store" class="mobile-nav-link mobile-nav-link-all">Ver toda la tienda →</a>
      <a href="/contacto" class="mobile-nav-link">Contáctanos</a>
    </div>
  </div>
</header>

<SearchOverlay
  collections={collections}
  suggestions={['pesca', 'caña', 'molinete', 'anzuelo', 'jigs', 'camping', 'rifle', 'outdoor']}
/>

<style>
  /* === Announcement bar === */
  .announce {
    background: var(--pine);
    color: var(--sand);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 9px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    overflow: hidden;
    gap: 20px;
  }
  .announce-track { flex: 1; overflow: hidden; min-width: 0; }
  .announce-reel {
    display: flex;
    gap: 56px;
    white-space: nowrap;
    animation: marquee 32s linear infinite;
  }
  .announce-reel span { flex-shrink: 0; opacity: 0.85; }
  .announce-reel span::before {
    content: "◆";
    margin-right: 12px;
    color: var(--terra-2);
  }
  .announce-right {
    display: flex;
    gap: 12px;
    align-items: center;
    opacity: 0.65;
    flex-shrink: 0;
    font-size: 10px;
  }
  .announce-right a { transition: opacity 0.15s; }
  .announce-right a:hover { opacity: 1; }

  /* === Header === */
  .hdr {
    background: var(--bg);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .hdr-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 18px 28px;
    gap: 24px;
    max-width: 1480px;
    margin: 0 auto;
  }

  /* Nav */
  .hdr-nav {
    display: flex;
    gap: 24px;
    align-items: center;
  }
  .hdr-link {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--fg);
    padding: 6px 0;
    position: relative;
    transition: color 0.15s;
    cursor: pointer;
    background: none;
    border: none;
    font-family: inherit;
  }
  .hdr-link:hover,
  .hdr-link.active { color: var(--terra); }

  /* Megamenu trigger */
  .hdr-megamenu-wrap { position: static; }
  .megamenu-trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .megamenu-trigger svg { transition: transform 0.2s; }
  .megamenu-trigger[aria-expanded="true"] svg { transform: rotate(180deg); }
  .megamenu-trigger[aria-expanded="true"] { color: var(--terra); }

  /* Brand mark */
  .brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    cursor: pointer;
    text-decoration: none;
    line-height: 0.9;
    white-space: nowrap;
  }
  .brand-mark {
    font-family: var(--font-display);
    font-size: 28px;
    letter-spacing: 0.04em;
    color: var(--pine);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    position: relative;
  }
  .brand-mark::before,
  .brand-mark::after {
    content: '';
    width: 16px;
    height: 1px;
    background: var(--fg);
    flex-shrink: 0;
  }
  .brand-sub {
    font-size: 9px;
    letter-spacing: 0.35em;
    color: var(--slate);
    text-transform: uppercase;
  }

  /* Actions */
  .hdr-actions {
    display: flex;
    justify-content: flex-end;
    gap: 4px;
    align-items: center;
  }
  .search-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--bg-2);
    border-radius: 999px;
    font-size: 12px;
    color: var(--slate);
    cursor: pointer;
    margin-right: 4px;
    white-space: nowrap;
    transition: background 0.15s;
    border: none;
    font-family: var(--font-body);
  }
  .search-pill:hover { background: var(--sand); }
  .search-pill kbd {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 2px 5px;
    border-radius: 3px;
    background: var(--bg);
    border: 1px solid var(--line);
    color: var(--slate);
    margin-left: auto;
  }
  .icon-btn {
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    color: var(--fg);
    transition: background 0.15s;
    position: relative;
    border: none;
    background: none;
    cursor: pointer;
  }
  .icon-btn:hover { background: var(--bg-2); }
  /* Cart button: accent color for visibility */
  [data-cart-toggle] {
    background: var(--terra);
    color: var(--white);
  }
  [data-cart-toggle]:hover {
    background: #a34d24;
  }
  .cart-badge {
    position: absolute;
    top: 2px;
    right: 2px;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    background: var(--terra);
    color: var(--white);
    border-radius: 999px;
    font-size: 10px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
  }
  .cart-badge[hidden] { display: none !important; }

  .hdr-hamburger { display: none; }

  /* Mobile drawer */
  .mobile-nav {
    display: none;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    background: var(--bg);
    border-top: 1px solid var(--line);
  }
  .mobile-nav[data-open] {
    max-height: 80vh;
    overflow-y: auto;
  }
  .mobile-nav-inner {
    display: flex;
    flex-direction: column;
    padding: 12px 20px 20px;
  }
  .mobile-nav-link {
    font-size: 15px;
    font-weight: 600;
    color: var(--fg);
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
    transition: color 0.15s;
  }
  .mobile-nav-link:hover { color: var(--terra); }
  .mobile-nav-link-all {
    color: var(--terra);
    margin-top: 8px;
    border-bottom: none;
  }

  @media (max-width: 900px) {
    .hdr-row {
      grid-template-columns: auto 1fr auto;
      padding: 14px 20px;
    }
    .hdr-nav { display: none; }
    .hdr-hamburger { display: inline-flex; }
    .mobile-nav { display: block; }
    .search-pill span,
    .search-pill kbd { display: none; }
    .search-pill { padding: 8px; border-radius: 999px; }
  }
  @media (max-width: 480px) {
    .announce-right { display: none; }
    .brand-mark { font-size: 22px; }
    .brand-mark::before, .brand-mark::after { width: 10px; }
  }
</style>

<script>
  // === Cart toggle ===
  document.querySelector('[data-cart-toggle]')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-cart'));
  });

  // === Search toggle ===
  document.querySelector('[data-search-toggle]')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-search'));
  });

  // === Mobile menu ===
  const menuToggle = document.querySelector('[data-menu-toggle]');
  const mobileNav = document.querySelector('[data-mobile-nav]');
  menuToggle?.addEventListener('click', () => {
    const isOpen = mobileNav?.hasAttribute('data-open');
    if (isOpen) {
      mobileNav?.removeAttribute('data-open');
      mobileNav?.setAttribute('aria-hidden', 'true');
      menuToggle.setAttribute('aria-expanded', 'false');
    } else {
      mobileNav?.setAttribute('data-open', '');
      mobileNav?.setAttribute('aria-hidden', 'false');
      menuToggle.setAttribute('aria-expanded', 'true');
    }
  });

  // === Megamenu ===
  const megamenuWrap = document.querySelector<HTMLElement>('[data-megamenu]');
  const megamenuTrigger = document.querySelector<HTMLButtonElement>('[data-megamenu-trigger]');
  const megamenuPanel = document.querySelector<HTMLElement>('[data-megamenu-panel]');

  function setMegaOpen(open: boolean) {
    if (!megamenuTrigger || !megamenuPanel) return;
    megamenuTrigger.setAttribute('aria-expanded', String(open));
    if (open) megamenuPanel.setAttribute('data-open', '');
    else megamenuPanel.removeAttribute('data-open');
  }

  let hoverTimer: ReturnType<typeof setTimeout> | null = null;
  megamenuWrap?.addEventListener('mouseenter', () => {
    if (hoverTimer) clearTimeout(hoverTimer);
    setMegaOpen(true);
  });
  megamenuWrap?.addEventListener('mouseleave', () => {
    hoverTimer = setTimeout(() => setMegaOpen(false), 150);
  });
  megamenuTrigger?.addEventListener('click', (e) => {
    e.preventDefault();
    const isOpen = megamenuTrigger.getAttribute('aria-expanded') === 'true';
    setMegaOpen(!isOpen);
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setMegaOpen(false);
  });
  document.addEventListener('click', (e) => {
    if (!megamenuWrap?.contains(e.target as Node)) setMegaOpen(false);
  });

  // === Active nav link ===
  const current = location.pathname;
  document.querySelectorAll<HTMLAnchorElement>('.hdr-link').forEach((a) => {
    const href = a.getAttribute('href') ?? '';
    if (href === current || (href !== '/' && current.startsWith(href))) {
      a.classList.add('active');
    }
  });

  // === Cart count ===
  async function initCartCount() {
    try {
      const { getCart } = await import('@skills-official/shopify-ecommerce/lib/cart-client');
      const cart = await getCart();
      const count = cart?.lines.reduce((s: number, l: any) => s + l.quantity, 0) ?? 0;
      const badge = document.querySelector('[data-cart-count]') as HTMLElement | null;
      if (badge) {
        badge.textContent = String(count);
        if (count === 0) badge.setAttribute('hidden', '');
        else badge.removeAttribute('hidden');
      }
    } catch { /* ignore */ }
  }
  initCartCount();
  document.addEventListener('cart-updated', () => initCartCount());
</script>
