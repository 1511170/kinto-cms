---
interface Section {
  title: string;
  body?: string;
  bullets?: string[];
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  updated: string;
  sections: Section[];
  ctaTitle?: string;
  ctaText?: string;
}

const {
  eyebrow,
  title,
  description,
  updated,
  sections,
  ctaTitle = '¿Necesitas confirmar un caso específico?',
  ctaText = 'Escríbenos por WhatsApp o visita una de nuestras tiendas. Te ayudamos a revisar disponibilidad, cobertura, tiempos y condiciones aplicables antes de comprar.',
} = Astro.props;
---

<nav class="policy-crumb" aria-label="Breadcrumb">
  <a href="/">Inicio</a>
  <span>/</span>
  <span>{title}</span>
</nav>

<section class="policy-hero">
  <div class="policy-eyebrow">{eyebrow}</div>
  <h1>{title}</h1>
  <p>{description}</p>
  <small>Última actualización: {updated}</small>
</section>

<section class="policy-wrap" aria-label={title}>
  <div class="policy-note">
    <strong>Información importante:</strong> estas condiciones aplican para compras realizadas con El Norteño en Colombia. Algunos productos, especialmente categorías reguladas o sensibles, pueden requerir validaciones adicionales de disponibilidad, despacho, edad mínima, logística o normativa aplicable.
  </div>

  {sections.map((section) => (
    <article class="policy-card">
      <h2>{section.title}</h2>
      {section.body && <p>{section.body}</p>}
      {section.bullets && (
        <ul>
          {section.bullets.map((item) => <li>{item}</li>)}
        </ul>
      )}
    </article>
  ))}

  <aside class="policy-cta">
    <h2>{ctaTitle}</h2>
    <p>{ctaText}</p>
    <div class="policy-actions">
      <a class="policy-btn policy-btn-primary" href="https://wa.me/573156819303" target="_blank" rel="noopener">WhatsApp Bucaramanga</a>
      <a class="policy-btn" href="/contacto">Ver tiendas y teléfonos</a>
    </div>
  </aside>
</section>

<style>
  .policy-crumb {
    max-width: 1120px;
    margin: 24px auto 0;
    padding: 0 20px;
    display: flex;
    gap: 10px;
    align-items: center;
    color: #66736b;
    font-size: 14px;
  }
  .policy-crumb a { color: #2b3a32; font-weight: 700; text-decoration: none; }
  .policy-hero {
    max-width: 1120px;
    margin: 22px auto 28px;
    padding: 48px 28px;
    border-radius: 28px;
    color: #f8f2e8;
    background:
      linear-gradient(135deg, rgba(20,32,26,.96), rgba(43,58,50,.9)),
      radial-gradient(circle at 18% 12%, rgba(226,159,63,.28), transparent 34%);
    box-shadow: 0 22px 60px rgba(20,32,26,.18);
  }
  .policy-eyebrow {
    color: #e2a34f;
    text-transform: uppercase;
    font-size: 13px;
    letter-spacing: .18em;
    font-weight: 900;
    margin-bottom: 12px;
  }
  .policy-hero h1 {
    margin: 0;
    max-width: 900px;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: .02em;
    line-height: .95;
    font-size: clamp(42px, 8vw, 88px);
  }
  .policy-hero p {
    max-width: 820px;
    margin: 20px 0 14px;
    color: rgba(248,242,232,.9);
    font-size: clamp(17px, 2vw, 21px);
  }
  .policy-hero small { color: rgba(248,242,232,.72); font-weight: 700; }
  .policy-wrap {
    max-width: 1120px;
    margin: 0 auto 72px;
    padding: 0 20px;
    display: grid;
    gap: 18px;
  }
  .policy-note,
  .policy-card,
  .policy-cta {
    border: 1px solid rgba(43,58,50,.12);
    border-radius: 22px;
    background: rgba(255,252,246,.82);
    box-shadow: 0 12px 34px rgba(20,32,26,.07);
  }
  .policy-note { padding: 18px 20px; color: #33443a; }
  .policy-card { padding: 26px; }
  .policy-card h2,
  .policy-cta h2 {
    margin: 0 0 10px;
    color: #1d2e25;
    font-size: clamp(22px, 3vw, 32px);
    line-height: 1.1;
  }
  .policy-card p { margin: 0; color: #3f4f45; }
  .policy-card ul { margin: 12px 0 0; padding-left: 1.2rem; color: #3f4f45; }
  .policy-card li { margin: 8px 0; }
  .policy-cta {
    padding: 28px;
    background: linear-gradient(135deg, #f9f2e3, #fffaf0);
  }
  .policy-cta p { max-width: 820px; color: #3f4f45; }
  .policy-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 18px; }
  .policy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 10px 18px;
    border-radius: 999px;
    border: 1px solid rgba(43,58,50,.18);
    color: #1d2e25;
    font-weight: 900;
    text-decoration: none;
    background: #fffdf8;
  }
  .policy-btn-primary { color: white; background: #1d2e25; border-color: #1d2e25; }
  @media (max-width: 720px) {
    .policy-hero { margin-inline: 14px; padding: 36px 22px; }
    .policy-card, .policy-cta { padding: 22px; }
    .policy-actions { flex-direction: column; }
  }
</style>
