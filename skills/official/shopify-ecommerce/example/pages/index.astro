---
import type { Product, Collection } from '../lib/product-mapper';
import { fetchAllProducts, fetchAllCollections } from '../lib/shopify-fetch';
import { mapShopifyProduct, mapShopifyCollection, generateSearchIndex } from '../lib/product-mapper';
import StoreHeader from '../components/layout/StoreHeader.astro';
import StoreFooter from '../components/layout/StoreFooter.astro';
import SearchOverlay from '../components/layout/SearchOverlay.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';
import ProductCard from '../components/product/ProductCard.astro';
import OrganizationSchema from '../components/seo/OrganizationSchema.astro';
import LittledataPixel from '../components/tracking/LittledataPixel.astro';
import GTMSetup from '../components/tracking/GTMSetup.astro';

const options = {
  storeDomain: import.meta.env.SHOPIFY_STORE_DOMAIN,
  storefrontAccessToken: import.meta.env.SHOPIFY_STOREFRONT_ACCESS_TOKEN,
  apiVersion: import.meta.env.SHOPIFY_API_VERSION ?? '2026-04',
};

const [rawProducts, rawCollections] = await Promise.all([
  fetchAllProducts(options),
  fetchAllCollections(options),
]);

const products = rawProducts.map(mapShopifyProduct);
const collections = rawCollections.map(mapShopifyCollection);

const featuredHandles = (import.meta.env.SHOPIFY_FEATURED_COLLECTIONS ?? '').split(',').filter(Boolean);
const featuredCollections = collections.filter((c: Collection) => featuredHandles.includes(c.handle));
const bestsellers = products.slice(0, 8);
const newArrivals = products.slice(8, 12);

export function getStaticPaths() {
  return [{ params: {} }];
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tu Tienda — Hardware ejecutado correctamente</title>
  <meta name="description" content="Premium hardware and electronics. Radical transparency in specs, pricing, and performance." />
  <link rel="canonical" href={Astro.url.href} />
  <OrganizationSchema
    name="Tu Tienda"
    url={Astro.site?.origin ?? ''}
    logo="/logo.svg"
    description="Premium hardware and electronics with radical transparency."
  />
  <LittledataPixel trackerId={import.meta.env.LITTLEDATA_TRACKER_ID ?? ''} />
  <GTMSetup containerId={import.meta.env.GTM_CONTAINER_ID ?? ''} />
</head>
<body class="bg-white text-gray-900 antialiased">
  <StoreHeader collections={collections} />
  <SearchOverlay collections={collections} />
  <CartDrawer />

  <main>
    <!-- Hero -->
    <section class="relative h-[70vh] min-h-[500px] flex items-center justify-center bg-gradient-to-br from-gray-50 to-gray-100">
      <div class="max-w-7xl mx-auto px-6 text-center">
        <p class="font-mono text-sm tracking-widest uppercase text-gray-500 mb-4">Premium Hardware</p>
        <h1 class="text-5xl md:text-7xl font-bold tracking-tight leading-none mb-6">
          Hardware ejecutado<br />correctamente
        </h1>
        <p class="text-lg text-gray-600 max-w-xl mx-auto mb-8">
          Publicamos specs completos, tolerancias de medicion y manuales de reparacion. Incluso cuando las metricas no son favorables.
        </p>
        <a href="/store" class="inline-block px-8 py-3 bg-[var(--accent,#1f1f1f)] text-white rounded-lg font-mono text-sm hover:opacity-90 transition-opacity">
          Ver catalogo
        </a>
      </div>
    </section>

    <!-- Bestsellers -->
    <section class="max-w-7xl mx-auto px-6 py-20">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-2xl font-bold tracking-tight">Mas vendidos</h2>
        <a href="/store" class="font-mono text-sm text-gray-500 hover:text-gray-900">Ver todo →</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {bestsellers.map((product: Product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </section>

    <!-- Collections -->
    {featuredCollections.length > 0 && (
      <section class="max-w-7xl mx-auto px-6 py-20">
        <h2 class="text-2xl font-bold tracking-tight mb-8">Colecciones</h2>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
          {featuredCollections.map((col: Collection) => (
            <a href={`/store/${col.handle}`} class="group block rounded-xl overflow-hidden bg-gray-50 hover:bg-gray-100 transition-colors">
              {col.image && (
                <div class="aspect-[4/3] bg-gray-200 overflow-hidden">
                  <img src={col.image.url} alt={col.image.altText ?? col.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform" loading="lazy" />
                </div>
              )}
              <div class="p-4">
                <h3 class="font-bold text-lg">{col.title}</h3>
                {col.description && <p class="text-sm text-gray-500 mt-1 line-clamp-2">{col.description}</p>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- New Arrivals -->
    {newArrivals.length > 0 && (
      <section class="max-w-7xl mx-auto px-6 py-20">
        <div class="flex items-baseline justify-between mb-8">
          <h2 class="text-2xl font-bold tracking-tight">Recien llegados</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          {newArrivals.map((product: Product) => (
            <ProductCard product={product} />
          ))}
        </div>
      </section>
    )}

    <!-- Manifesto -->
    <section class="bg-gray-50 py-20">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="font-mono text-xs tracking-widest uppercase text-gray-400 mb-4">Nuestro manifesto</p>
        <blockquote class="text-xl md:text-2xl font-medium leading-relaxed text-gray-700">
          "Publicamos specs completos — incluso cuando no son favorables. Creemos que la transparencia radical es la unica forma de construir confianza duradera."
        </blockquote>
      </div>
    </section>
  </main>

  <StoreFooter collections={collections} />
</body>
</html>
