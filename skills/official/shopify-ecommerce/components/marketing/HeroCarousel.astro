---
import { shopifyImageUrl, shopifySrcSet, IMAGE_SIZES, SRCSET_WIDTHS } from '../../lib/shopify-image';

export interface HeroSlide {
  eyebrow: string;
  title: string;
  tagline?: string;
  meta?: { label: string; value: string }[];
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  image?: { url: string; altText?: string };
  accent?: string;
}

interface Props {
  slides: HeroSlide[];
  layout?: 'split' | 'full-bleed' | 'centered';
  autoAdvanceMs?: number;
}

const { slides, layout = 'split', autoAdvanceMs = 6000 } = Astro.props;
---

<section class="hero" data-hero data-auto={autoAdvanceMs}>
  <div class="hero-stage shell" data-layout={layout}>
    {slides.map((slide, i) => (
      <div class={`hero-slide ${i === 0 ? 'active' : ''}`} data-slide-index={i}>
        <div class="hero-slide-text">
          <div class="hero-eye eyebrow">
            {slide.accent && <span class="hero-swatch" style={`background:${slide.accent}`}></span>}
            <span>Colección {String(i + 1).padStart(2, '0')} / {String(slides.length).padStart(2, '0')}</span>
            <span aria-hidden="true">·</span>
            <span>{slide.eyebrow}</span>
          </div>
          <h1 class="hero-title h-display">{slide.title}</h1>
          {slide.tagline && <p class="hero-tagline">{slide.tagline}</p>}
          {slide.meta && slide.meta.length > 0 && (
            <div class="hero-meta">
              {slide.meta.map((m) => (
                <span><b>{m.value}</b> {m.label}</span>
              ))}
            </div>
          )}
          <div class="hero-cta">
            {slide.ctaPrimary && (
              <a class="btn btn-lg" href={slide.ctaPrimary.href}>
                {slide.ctaPrimary.label}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            )}
            {slide.ctaSecondary && (
              <a class="btn btn-ghost btn-lg" href={slide.ctaSecondary.href}>{slide.ctaSecondary.label}</a>
            )}
          </div>
        </div>
        <div class="hero-visual">
          {slide.image ? (
            <img
              src={shopifyImageUrl(slide.image.url, IMAGE_SIZES.hero)}
              srcset={shopifySrcSet(slide.image.url, SRCSET_WIDTHS.hero)}
              sizes="100vw"
              alt={slide.image.altText ?? slide.title}
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : undefined}
              decoding="async"
            />
          ) : (
            <div class="hero-placeholder">
              <span class="hero-placeholder-label mono">{slide.eyebrow} — Press image</span>
            </div>
          )}
        </div>
      </div>
    ))}

    <div class="hero-controls">
      <button class="hero-arrow" data-hero-prev aria-label="Anterior">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button class="hero-arrow" data-hero-next aria-label="Siguiente">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <span class="hero-counter mono" data-hero-counter>01 — {String(slides.length).padStart(2, '0')}</span>
    </div>

    <div class="hero-dots" role="tablist">
      {slides.map((_, i) => (
        <button class={`hero-dot ${i === 0 ? 'active' : ''}`} data-hero-dot={i} aria-label={`Slide ${i + 1}`}></button>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--bg);
    border-bottom: 1px solid var(--line);
  }
  .hero-stage {
    position: relative;
    min-height: 600px;
    padding: 64px 32px 96px;
  }
  .hero-slide {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    position: absolute;
    inset: 64px 32px 96px;
    transition: opacity .6s ease;
  }
  .hero-slide.active {
    opacity: 1;
    visibility: visible;
    position: relative;
    inset: auto;
  }
  .hero-stage[data-layout="full-bleed"] .hero-slide {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .hero-stage[data-layout="full-bleed"] .hero-visual { display: none; }
  .hero-stage[data-layout="centered"] .hero-slide {
    grid-template-columns: 1fr;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }
  .hero-stage[data-layout="centered"] .hero-visual { display: none; }

  .hero-eye {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
  }
  .hero-swatch {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    display: inline-block;
  }
  .hero-title {
    font-size: clamp(48px, 6.4vw, 96px);
    margin: 0 0 24px;
    color: var(--fg);
  }
  .hero-tagline {
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.5;
    color: var(--fg-muted);
    max-width: 520px;
    margin: 0 0 28px;
  }
  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin-bottom: 32px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .hero-meta b { color: var(--fg); font-weight: 500; }
  .hero-cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .hero-visual {
    position: relative;
    aspect-ratio: 4 / 5;
    background: var(--bg-soft);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .hero-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-placeholder {
    width: 100%;
    height: 100%;
    background-image: repeating-linear-gradient(135deg, transparent 0 6px, var(--line) 6px 7px);
    display: flex;
    align-items: flex-end;
    padding: 16px;
  }
  .hero-placeholder-label {
    font-size: 10px;
    background: var(--bg);
    padding: 6px 10px;
    border: 1px solid var(--line);
    color: var(--fg-muted);
  }

  .hero-controls {
    position: absolute;
    bottom: 32px;
    right: 32px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .hero-arrow {
    width: 36px;
    height: 36px;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    color: var(--fg);
    transition: background .15s, border-color .15s;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .hero-arrow:hover {
    background: var(--fg);
    color: var(--bg);
    border-color: var(--fg);
  }
  .hero-counter {
    font-size: 11px;
    color: var(--fg-muted);
    margin-left: 8px;
    letter-spacing: 0.08em;
  }
  .hero-dots {
    position: absolute;
    bottom: 40px;
    left: 32px;
    display: flex;
    gap: 6px;
  }
  .hero-dot {
    width: 24px;
    height: 2px;
    background: var(--line-strong);
    transition: background .2s;
  }
  .hero-dot.active { background: var(--fg); }

  @media (max-width: 900px) {
    .hero-slide { grid-template-columns: 1fr; gap: 32px; }
    .hero-controls, .hero-dots { position: static; margin-top: 24px; }
    .hero-stage { padding: 32px 20px 56px; min-height: auto; }
  }
</style>

<script>
  function initHero(root: HTMLElement) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('.hero-slide'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('[data-hero-dot]'));
    const counter = root.querySelector<HTMLElement>('[data-hero-counter]');
    const prevBtn = root.querySelector<HTMLElement>('[data-hero-prev]');
    const nextBtn = root.querySelector<HTMLElement>('[data-hero-next]');
    const auto = Number(root.dataset.auto ?? 6000);
    const total = slides.length;
    if (total <= 1) return;

    let current = 0;
    let timer: number | null = null;

    function go(idx: number) {
      current = (idx + total) % total;
      slides.forEach((s, i) => s.classList.toggle('active', i === current));
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
      if (counter) counter.textContent = `${String(current + 1).padStart(2, '0')} — ${String(total).padStart(2, '0')}`;
    }

    function start() {
      stop();
      timer = window.setInterval(() => go(current + 1), auto);
    }
    function stop() {
      if (timer) { clearInterval(timer); timer = null; }
    }

    prevBtn?.addEventListener('click', () => { go(current - 1); start(); });
    nextBtn?.addEventListener('click', () => { go(current + 1); start(); });
    dots.forEach((d) => d.addEventListener('click', () => {
      const i = Number(d.dataset.heroDot);
      go(i); start();
    }));

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);

    start();
  }

  document.querySelectorAll<HTMLElement>('[data-hero]').forEach(initHero);
</script>
