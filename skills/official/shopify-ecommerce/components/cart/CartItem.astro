---
import type { CartLine } from '../../lib/product-mapper';
import { formatPrice } from '../../lib/format-price';
import { shopifyImageUrl, IMAGE_SIZES } from '../../lib/shopify-image';

interface Props {
  line: CartLine;
}

const { line } = Astro.props;
---

<div data-cart-item={line.id} class="flex gap-4 py-5 border-b border-line last:border-b-0">
  <div class="flex-shrink-0 w-20 h-20 rounded-md overflow-hidden bg-bg-soft border border-line">
    {line.merchandise.image ? (
      <img
        src={shopifyImageUrl(line.merchandise.image.url, IMAGE_SIZES.cart)}
        alt={line.merchandise.image.altText || line.merchandise.title}
        width={line.merchandise.image.width}
        height={line.merchandise.image.height}
        loading="lazy"
        class="w-full h-full object-cover"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-fg-faint">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
        </svg>
      </div>
    )}
  </div>

  <div class="flex-1 min-w-0 space-y-1">
    <h4 class="text-sm font-medium text-fg truncate">
      {line.merchandise.title}
    </h4>

    {line.merchandise.title !== 'Default Title' && (
      <p class="text-[10px] font-mono text-fg-muted uppercase tracking-wider">
        {line.merchandise.title}
      </p>
    )}

    <p class="text-[11px] font-mono text-fg-faint">
      {formatPrice(line.merchandise.price.amount, line.merchandise.price.currencyCode)} c/u
    </p>

    <div class="flex items-center gap-2 pt-1">
      <div class="inline-flex items-center border border-line-strong rounded-sm overflow-hidden h-7">
        <button
          data-qty-minus
          data-line-id={line.id}
          class="w-7 h-7 flex items-center justify-center text-fg-muted hover:text-fg hover:bg-bg-soft transition-colors"
          aria-label="Disminuir cantidad"
        >
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" /></svg>
        </button>
        <span data-qty-display class="w-8 h-7 flex items-center justify-center text-xs font-mono font-medium text-fg border-x border-line">
          {line.quantity}
        </span>
        <button
          data-qty-plus
          data-line-id={line.id}
          class="w-7 h-7 flex items-center justify-center text-fg-muted hover:text-fg hover:bg-bg-soft transition-colors"
          aria-label="Aumentar cantidad"
        >
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
        </button>
      </div>

      <button
        data-remove-item
        data-line-id={line.id}
        class="w-7 h-7 flex items-center justify-center rounded-sm text-fg-faint hover:text-warn hover:bg-bg-soft transition-colors"
        aria-label="Eliminar"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/>
          <path d="M10 11v6M14 11v6"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="flex-shrink-0 text-right">
    <span class="text-sm font-mono font-semibold text-fg">
      {formatPrice(line.cost.subtotalAmount.amount, line.cost.subtotalAmount.currencyCode)}
    </span>
  </div>
</div>
