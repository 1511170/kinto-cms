---
import type { Image } from '../../lib/product-mapper';
import { shopifyImageUrl, IMAGE_SIZES } from '../../lib/shopify-image';

interface Props {
  title: string;
  description: string;
  image: Image | null;
}

const { title, description, image } = Astro.props;
---

<header class="relative overflow-hidden rounded-xl bg-gray-50 border border-gray-100">
  {image ? (
    <div class="relative">
      <img
        src={shopifyImageUrl(image.url, IMAGE_SIZES.hero)}
        alt={image.altText || title}
        width={image.width}
        height={image.height}
        class="w-full h-48 md:h-64 lg:h-80 object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent" />
    </div>
  ) : (
    <div class="h-32 md:h-48 bg-gradient-to-br from-gray-100 to-gray-50" />
  )}

  <div class="absolute inset-0 flex flex-col justify-end p-6 md:p-10">
    <h1 class="text-2xl md:text-4xl lg:text-5xl font-medium text-white drop-shadow-sm">
      {title}
    </h1>
    {description && (
      <p class="mt-2 text-sm md:text-base text-white/80 max-w-xl leading-relaxed">
        {description}
      </p>
    )}
  </div>
</header>
