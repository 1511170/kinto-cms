---
import type { Product } from '../../lib/product-mapper';
import SchemaOrg from '@skills-community/seo-ai-citations/components/SchemaOrg.astro';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const faqs = product.metafields?.faqs ?? [];
---

{faqs.length > 0 && <SchemaOrg type="FAQPage" faqs={faqs} />}
