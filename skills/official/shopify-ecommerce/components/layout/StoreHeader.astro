---
import type { Collection } from '../../lib/product-mapper';

interface Props {
  collections: Collection[];
  brandName?: string;
}

const { collections, brandName = 'Tu Tienda' } = Astro.props;

const INTERNAL_HANDLES = new Set(['frontpage', 'home-page', 'home', 'all']);
const publicCollections = collections.filter((c) => !INTERNAL_HANDLES.has(c.handle.toLowerCase()));
const navCollections = publicCollections.slice(0, 5);
const mobileNavCollections = publicCollections.slice(0, 8);
---

<header data-store-header class="hdr">
  <div class="shell hdr-row">
    <!-- Left: Nav (desktop) / Menu toggle (mobile) -->
    <nav class="hdr-nav" aria-label="Colecciones">
      {navCollections.map((col) => (
        <a href={`/store/${col.handle}`} class="hdr-link">{col.title}</a>
      ))}
      <a href="/store" class="hdr-link hdr-link-strong">Tienda</a>
    </nav>

    <!-- Center: Logo -->
    <a href="/" class="hdr-logo h-display" aria-label={brandName}>
      <span>{brandName}</span><span class="hdr-logo-dot">.</span>
    </a>

    <!-- Right: Actions -->
    <div class="hdr-actions">
      <button data-search-toggle class="hdr-icon" aria-label="Buscar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
        </svg>
      </button>
      <a href="/contacto" class="hdr-icon" aria-label="Contacto y soporte">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      </a>
      <button data-cart-toggle class="hdr-icon hdr-icon-cart" aria-label="Carrito">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 6h15l-1.5 9H7.5L6 6z"/><path d="M6 6 5 3H2"/>
          <circle cx="9" cy="20" r="1.5"/><circle cx="18" cy="20" r="1.5"/>
        </svg>
        <span data-cart-count class="hdr-cart-count" hidden>0</span>
      </button>
    </div>
  </div>

  <!-- Mobile nav scrollable -->
  <nav class="hdr-mobile-nav" aria-label="Colecciones móvil">
    {mobileNavCollections.map((col) => (
      <a href={`/store/${col.handle}`} class="hdr-mobile-link mono">{col.title}</a>
    ))}
  </nav>
</header>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--line);
  }
  .hdr-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 64px;
  }
  .hdr-nav {
    display: flex;
    gap: 28px;
    align-items: center;
  }
  .hdr-link {
    font-size: 13px;
    font-weight: 500;
    color: var(--fg);
    transition: color .15s;
    position: relative;
    padding: 4px 0;
  }
  .hdr-link:hover { color: var(--accent-2); }
  .hdr-link-strong { color: var(--fg); font-weight: 600; }
  .hdr-link.active::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -2px;
    height: 2px;
    background: var(--fg);
  }
  .hdr-logo {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.04em;
    color: var(--fg);
    display: inline-flex;
    align-items: center;
  }
  .hdr-logo-dot { color: var(--accent-2); }
  .hdr-actions {
    display: flex;
    gap: 4px;
    justify-content: flex-end;
    align-items: center;
  }
  .hdr-icon {
    width: 36px; height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    color: var(--fg);
    transition: background .15s;
    position: relative;
  }
  .hdr-icon:hover { background: var(--bg-soft); }
  .hdr-icon-cart .hdr-cart-count {
    position: absolute;
    top: 2px; right: 2px;
    min-width: 16px;
    height: 16px;
    border-radius: 999px;
    background: var(--accent-2);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
  }
  .hdr-cart-count[hidden] { display: none !important; }

  .hdr-mobile-nav {
    display: none;
    overflow-x: auto;
    gap: 16px;
    padding: 0 20px 10px;
    scrollbar-width: none;
  }
  .hdr-mobile-nav::-webkit-scrollbar { display: none; }
  .hdr-mobile-link {
    flex-shrink: 0;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-muted);
    padding: 4px 0;
  }

  @media (max-width: 900px) {
    .hdr-row {
      grid-template-columns: auto 1fr auto;
      padding: 0 4px;
    }
    .hdr-nav { display: none; }
    .hdr-mobile-nav { display: flex; }
  }
</style>

<script>
  document.querySelector('[data-cart-toggle]')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-cart'));
  });
  document.querySelector('[data-search-toggle]')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-search'));
  });

  async function initCartCount() {
    try {
      const { getCart } = await import('../../lib/cart-client');
      const cart = await getCart();
      const count = cart?.lines.reduce((sum, l) => sum + l.quantity, 0) ?? 0;
      const badge = document.querySelector('[data-cart-count]') as HTMLElement | null;
      if (badge) {
        badge.textContent = String(count);
        if (count === 0) badge.setAttribute('hidden', '');
        else badge.removeAttribute('hidden');
      }
    } catch { /* ignore */ }
  }

  initCartCount();

  // Reagregar count cuando el cart se actualiza
  document.addEventListener('cart-updated', () => initCartCount());
</script>
