# Shopify Storefront API
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=shpat_xxxxxxxxxxxxx
SHOPIFY_API_VERSION=2026-04
SHOPIFY_CURRENCY_CODE=USD
SHOPIFY_LOCALE=en-US
SHOPIFY_FEATURED_COLLECTIONS=collection-handle-1,collection-handle-2

# Tracking
LITTLEDATA_TRACKER_ID=
GA_MEASUREMENT_ID=G-XXXXXX
GTM_CONTAINER_ID=GTM-XXXX

# Checkout
SHOPIFY_CHECKOUT_SAME_DOMAIN=true
SHOPIFY_CHECKOUT_SUBDOMAIN=checkout
