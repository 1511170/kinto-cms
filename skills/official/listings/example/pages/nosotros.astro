---
import Base from "@layouts/Base.astro";
---
<Base title="Nosotros" active="nosotros" description="Más de 15 años de experiencia inmobiliaria en Arauca.">
  <section class="cabecera-pagina">
    <div class="contenedor">
      <div class="migas"><a href="/">Inicio</a> / Nosotros</div>
      <h1>Sobre Inmobiliaria Arauca</h1>
      <p class="sub">Conectamos familias con su hogar ideal, con respaldo y transparencia.</p>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <div class="grid-3">
        <div class="card-plana"><div class="num-grande">+15</div><h3>Años de experiencia</h3><p>Trayectoria sólida en el mercado inmobiliario de Arauca.</p></div>
        <div class="card-plana"><div class="num-grande">+90</div><h3>Inmuebles gestionados</h3><p>Arriendo, venta y administración de propiedades.</p></div>
        <div class="card-plana"><div class="num-grande">100%</div><h3>Documentación al día</h3><p>Procesos claros y seguros para propietarios e inquilinos.</p></div>
      </div>
    </div>
  </section>

  <section class="seccion seccion-suave">
    <div class="contenedor">
      <div class="seccion-cabecera"><div><span class="kicker">Cómo trabajamos</span><h2>Un proceso simple</h2></div></div>
      <div class="grid-3">
        <div class="card-plana"><h3>1. Cuéntanos qué buscas</h3><p>Entendemos tu necesidad, presupuesto y zona preferida.</p></div>
        <div class="card-plana"><h3>2. Te mostramos opciones</h3><p>Seleccionamos inmuebles que encajan y coordinamos visitas.</p></div>
        <div class="card-plana"><h3>3. Cerramos con respaldo</h3><p>Acompañamiento legal y administrativo hasta la firma.</p></div>
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <div class="banda-cta">
        <div><h2>¿Tienes un inmueble para arrendar o vender?</h2><p>Consígnalo con nosotros y nos encargamos de todo.</p></div>
        <a href="/contacto" class="btn btn-rojo btn-grande">Consignar inmueble</a>
      </div>
    </div>
  </section>
</Base>
