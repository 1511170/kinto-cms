---
import Base from "@layouts/Base.astro";
import ListingCard from "@components/ListingCard.astro";
import { fetchAllListings } from "@lib/listings/sedi-client";
import { LISTINGS_CONFIG } from "@lib/listings/config/listings.config";
import { precioConSufijo, tituloListing, whatsappLink, formatPrecio } from "@lib/listings/format";
import { geocode, type GeoResult } from "@lib/listings/geocode";
import type { Listing } from "@lib/listings/types";

export async function getStaticPaths() {
  const listings = await fetchAllListings({ soloDisponibles: true });
  const paths = [];
  for (const l of listings) {
    const geo = await geocode(l.direccion, l.ciudad, l.barrio);
    paths.push({ params: { slug: l.slug }, props: { listing: l, todos: listings, geo } });
  }
  return paths;
}

const { listing, todos, geo } = Astro.props as { listing: Listing; todos: Listing[]; geo: GeoResult };
const l = listing;
const brand = LISTINGS_CONFIG.brand;
const titulo = tituloListing(l);
const esArriendo = l.operacion.includes("arriendo");
const badgeClass = l.operacion === "venta" ? "badge-venta" : "badge-arriendo";
const badgeText = l.operacion === "venta" ? "En venta" : "En arriendo";

const msg = `Hola, me interesa el inmueble ${titulo} (Ref. ${l.ref}) que vi en el sitio web. ${Astro.url}`;
const wa = whatsappLink(brand.whatsapp, msg);

const caracteristicas = [
  l.habitaciones ? { valor: l.habitaciones, etiqueta: "Habitaciones" } : null,
  l.banos ? { valor: l.banos, etiqueta: l.banos === 1 ? "Baño" : "Baños" } : null,
  l.area ? { valor: `${l.area}`, etiqueta: "m² const." } : null,
  l.parqueaderos ? { valor: l.parqueaderos, etiqueta: "Parqueaderos" } : null,
  l.estrato ? { valor: l.estrato, etiqueta: "Estrato" } : null,
].filter(Boolean) as { valor: string | number; etiqueta: string }[];

const galeria = l.fotos.slice(0, 5);
// Similares: misma operación; priorizar los que tienen foto y mismo tipo.
const similares = todos
  .filter((x) => x.id !== l.id && x.operacion === l.operacion)
  .sort((a, b) => {
    const score = (x: Listing) => (x.fotos.length ? 2 : 0) + (x.tipo === l.tipo ? 1 : 0);
    return score(b) - score(a);
  })
  .slice(0, 3);
// Mapa OpenStreetMap (gratis, sin API key). bbox alrededor de la coordenada.
const dLon = 0.006, dLat = 0.004;
const bbox = `${geo.lon - dLon},${geo.lat - dLat},${geo.lon + dLon},${geo.lat + dLat}`;
const mapaSrc = `https://www.openstreetmap.org/export/embed.html?bbox=${bbox}&layer=mapnik${geo.exact ? `&marker=${geo.lat},${geo.lon}` : ""}`;
const mapaLink = `https://www.openstreetmap.org/?mlat=${geo.lat}&mlon=${geo.lon}#map=16/${geo.lat}/${geo.lon}`;

const schema = {
  "@context": "https://schema.org",
  "@type": "RealEstateListing",
  name: titulo,
  description: l.descripcion?.slice(0, 300),
  url: Astro.url.toString(),
  image: l.fotos.map((f) => f.url).slice(0, 8),
  datePosted: new Date().toISOString(),
  ...(l.precio ? { offers: { "@type": "Offer", price: l.precio, priceCurrency: "COP", availability: "https://schema.org/InStock" } } : {}),
  address: { "@type": "PostalAddress", streetAddress: l.direccion, addressLocality: l.ciudad || "Arauca", addressRegion: "Arauca", addressCountry: "CO" },
};
---
<Base title={titulo} active="inmuebles" description={l.descripcion?.slice(0, 155) || titulo}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />

  <div class="contenedor" style="padding-top:24px">
    <div class="migas"><a href="/">Inicio</a> / <a href="/inmuebles">Inmuebles</a> / {l.tipo}</div>

    {galeria.length > 0 ? (
      <div class="galeria">
        {galeria.map((f) => (
          <div class="celda"><img src={f.url} alt={titulo} class="img-cover" width="800" height="600" /></div>
        ))}
      </div>
    ) : (
      <div class="galeria"><div class="celda ph" data-label="Sin fotos" style="grid-column:1/-1"></div></div>
    )}

    <div class="layout-detalle">
      <div>
        <div class="detalle-titulo">
          <span class={`badge ${badgeClass}`}>{badgeText}</span>
          <h1>{titulo}</h1>
          <p class="detalle-direccion">{l.direccion}</p>
        </div>

        {caracteristicas.length > 0 && (
          <div class="fila-caracteristicas">
            {caracteristicas.map((c) => (
              <div class="caracteristica">
                <span class="valor">{c.valor}</span>
                <span class="etiqueta">{c.etiqueta}</span>
              </div>
            ))}
          </div>
        )}

        {l.descripcion && (
          <div class="detalle-seccion">
            <h2>Descripción</h2>
            <p>{l.descripcion}</p>
          </div>
        )}

        <div class="detalle-seccion">
          <h2>Ubicación</h2>
          <p style="margin-bottom:14px">{l.barrio ? `${l.barrio}, ` : ""}{l.ciudad || "Arauca"}{!geo.exact ? " (ubicación aproximada)" : ""}</p>
          <iframe class="mapa-ph" style="width:100%;border:0" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Mapa" src={mapaSrc}></iframe>
          <p style="margin-top:10px"><a href={mapaLink} target="_blank" rel="noopener" class="btn btn-fantasma">Ver mapa más grande</a></p>
        </div>
      </div>

      <aside>
        <div class="tarjeta-contacto">
          <div>
            <span class="detalle-precio">
              {formatPrecio(l.precio)}{esArriendo && l.precio ? <span class="periodo"> /mes</span> : null}
            </span>
            <div style="margin-top:6px"><span class="badge badge-suave">{l.tipo}{l.barrio ? ` · ${l.barrio}` : ""}</span></div>
          </div>
          {l.valorAdministracion ? <p class="nota-codigo">Administración: {formatPrecio(l.valorAdministracion)}</p> : null}
          <div class="asesor">
            <div class="avatar">IA</div>
            <div>
              <div class="nombre">{brand.nombre}</div>
              <div class="rol">Asesor inmobiliario</div>
            </div>
          </div>
          <a href={wa} class="btn btn-wa btn-bloque" target="_blank" rel="noopener">Consultar por WhatsApp</a>
          <a href={`tel:${brand.telefono.replace(/\s/g, "")}`} class="btn btn-azul btn-bloque">Llamar</a>
          <a href={`mailto:${brand.email}?subject=${encodeURIComponent(`Consulta inmueble Ref. ${l.ref}`)}`} class="btn btn-fantasma btn-bloque">Correo</a>
          <p class="nota-codigo">Referencia: <strong>{l.ref}</strong></p>
        </div>
      </aside>
    </div>

    {similares.length > 0 && (
      <section class="seccion" style="padding-top:0">
        <div class="seccion-cabecera"><h2>Inmuebles similares</h2></div>
        <div class="grid-inmuebles">
          {similares.map((s) => (<ListingCard listing={s} />))}
        </div>
      </section>
    )}
  </div>
</Base>
