{
  "name": "kinto-cms",
  "version": "3.0.0",
  "description": "KINTO CMS — generador de sitios estáticos agent-native con arquitectura de skills",
  "type": "module",
  "bin": {
    "kinto": "./bin/kinto.js"
  },
  "files": [
    "bin/",
    "cli/",
    "core/",
    "skills/official/",
    "templates/",
    ".claude/",
    "AGENTS.md",
    "CLAUDE.md",
    "KINTO.md",
    "README.md"
  ],
  "scripts": {
    "kinto": "node bin/kinto.js",
    "start": "node bin/kinto.js start",
    "doctor": "node bin/kinto.js doctor",
    "skills:validate": "node bin/kinto.js skill validate",
    "marketplace": "node bin/kinto.js marketplace"
  },
  "keywords": [
    "astro",
    "static-site",
    "cms",
    "headless",
    "cloudflare",
    "shopify",
    "ecommerce",
    "ai-citations",
    "skills",
    "agent-native"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kinto-cms/kinto-cms.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "KINTO",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
