# Credenciales por cliente — NUNCA commitear .env-* (ver .gitignore)
# Copia este archivo a `.env-meta-ads` y completa los valores.

# Meta Ads CLI — System User + scopes ads_management, ads_read, business_management
META_ADS_API_VERSION=v22.0
META_ADS_ACCESS_TOKEN=<system-user-long-lived-token>
META_ADS_AD_ACCOUNT_ID=act_XXXXXXXXXX
META_ADS_BUSINESS_ID=<optional>

